---
import countryRegionData from 'country-region-data/data.json'

import CustomButton from './CustomButton.astro'
import FormField from './FormField.astro'

const { memberships } = Astro.props

const countries = countryRegionData.map((c) => c.countryName)
const membershipOptions = memberships.map((m: any, idx: number) => ({
  label: `${m.title} $${m.cost} USD`,
  value: idx,
  data: { 'data-title': m.title, 'data-cost': m.cost }
}))
---

<div class="font-body" id="join-us-form-root" data-memberships={JSON.stringify(memberships)}>
  <div class="
    mx-auto max-w-7xl space-y-12 px-6 py-12 text-black
    md:px-12
  ">
    <div class="space-y-6">
      <h1 class="font-heading text-4xl text-brand-dark-purple lowercase">
        Thank you for your interest!
      </h1>
      <p class="text-lg/relaxed text-gray-700">
        By filling out this form, you will be added to the email list. If you wish to also have a
        membership with Sakyadhita, you will be asked to pay a membership fee through PayPal once
        all required fields are filled out. If you wish to only be on the email list, please check
        the “Not interested in membership” box below.
      </p>

      <FormField
        id="membershipCheck"
        name="membershipCheck"
        type="checkbox"
        label="Not interested in membership, but want to be on the email list."
      />
    </div>

    <form
      name="membership"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      autocomplete="off"
      class="mx-auto max-w-2xl space-y-4"
      id="join-us-form"
    >
      <p class="hidden">
        <label>
          Don’t fill this out if you're human: <input name="bot-field" />
        </label>
      </p>
      <input type="hidden" name="form-name" value="membership" />

      <section class="space-y-4">
        <h1
          class="
            mt-12 mb-8 w-fit border-b-2 border-brand-orange pb-1 font-heading
            text-3xl text-brand-dark-purple lowercase italic
          "
        >
          Sign Me Up!
        </h1>
        <FormField id="fName" name="fName" placeholder="First Name" required />
        <FormField id="mName" name="mName" placeholder="Middle Name" />
        <FormField id="lName" name="lName" placeholder="Last Name" required />
      </section>

      <section class="space-y-4">
        <h1
          class="
            mt-16 mb-8 w-fit border-b-2 border-brand-orange pb-1 font-heading
            text-3xl text-brand-dark-purple lowercase italic
          "
        >
          Contact Information
        </h1>
        <FormField id="email" name="email" type="email" placeholder="Email Address" required />
        <FormField
          id="country-select"
          name="country"
          type="select"
          placeholder="Select Country"
          options={countries}
          required
        />

        {/* address fields - hidden by default, shown when country selected */}
        <div id="address-fields" class="
          hidden space-y-4 pt-2 fade-in slide-in-from-top-4
        ">
          <FormField id="addressOne" name="addressOne" placeholder="Address Line 1" required />
          <FormField id="addressTwo" name="addressTwo" placeholder="Address Line 2" />
          <FormField id="city" name="city" placeholder="City" required />
          <FormField id="stateLocation" name="stateLocation" placeholder="State" required />
          <FormField id="zipcode" name="zipcode" placeholder="Zip Code" required />
          <FormField id="phone" name="phone" placeholder="Phone Number" />
        </div>
      </section>

      {/* Membership specific sections */}
      <div id="membership-sections" class="space-y-8 pt-8 fade-in">
        <section class="space-y-4">
          <h1
            class="
              mt-12 mb-8 w-fit border-b-2 border-brand-orange pb-1 font-heading
              text-3xl text-brand-dark-purple lowercase italic
            "
          >
            Additional Information
          </h1>
          <FormField
            id="isNewMember"
            name="isNewMember"
            type="select"
            placeholder="New or Renewing Member?"
            options={[
              { label: 'New', value: 'new' },
              { label: 'Renewing', value: 'renew' }
            ]}
            required
          />
          <FormField
            id="affiliatedOrgs"
            name="affiliatedOrgs"
            type="textarea"
            placeholder="List any organizations you’re involved with"
            required
          />
        </section>

        <section class="space-y-4">
          <h1
            class="
              mt-16 mb-8 w-fit border-b-2 border-brand-orange pb-1 font-heading
              text-3xl text-brand-dark-purple lowercase italic
            "
          >
            Payment Options
          </h1>
          <FormField
            id="membership-select"
            name="membershipType"
            type="select"
            placeholder="Select Membership"
            options={membershipOptions}
            required
          />

          <FormField
            id="donateCheck"
            name="donateCheck"
            type="checkbox"
            className="mt-8!"
            label="I would like to donate in addition to membership fees"
          />

          <div id="donation-field" class="relative mt-4! hidden items-center">
            <div class="relative w-full">
              <span
                class="
                  absolute top-1/2 left-4 z-10 -translate-y-1/2 text-lg
                  font-bold text-black
                "
              >
                $
              </span>
              <input
                id="totalPaid"
                name="totalPaid"
                type="number"
                step="0.01"
                placeholder="Insert Donation Amount"
                class="
                  h-12 w-full rounded-2xl border border-black bg-white pl-10
                  font-body text-lg transition-all outline-none
                  focus-visible:border-brand-dark-purple focus-visible:ring-2
                  focus-visible:ring-brand-dark-purple
                "
              />
            </div>
            <span class="ml-2 shrink-0 text-xl font-bold text-brand-red">*</span>
          </div>
        </section>

        <div class="flex flex-col items-center space-y-6 pt-12">
          <div id="payment-button-container" class="hidden">
            <CustomButton
              className="h-16 w-auto rounded-full px-16 text-2xl"
              text="Continue to Payment"
              id="continue-to-payment"
            />
          </div>
          <div
            id="payment-requirement-notice"
            class="
              rounded-lg border border-brand-red/20 bg-brand-red/5 p-4
              text-center
            "
          >
            <p class="animate-pulse text-lg font-bold text-brand-red">
              *Please fill out all required fields to proceed to payment.
            </p>
          </div>
        </div>
      </div>

      {/* Email List Only submit button */}
      <div id="email-only-submit" class="hidden space-y-10 pt-16">
        <p class="text-center font-body text-lg text-gray-500 italic">
          <span class="font-bold text-brand-red"> * </span> indicates a required field
        </p>
        <div class="flex justify-center pb-12">
          <CustomButton
            className="h-16 w-auto rounded-full px-16 text-2xl"
            text="Submit"
            id="submit-email-only"
          />
        </div>
      </div>
    </form>
  </div>

  {/* PayPal Modal */}
  <div
    id="paypal-modal"
    class="
      fixed inset-0 z-1001 hidden items-center justify-center bg-black/80 p-4
    "
  >
    <div
      class="
        w-full max-w-xl rounded-lg border-2 border-brand-orange bg-white p-8
        shadow-lg fade-in zoom-in-95
      "
    >
      <h1 class="
        mb-8 text-center font-heading text-2xl font-bold text-brand-dark-purple
        lowercase
      ">
        Choose Your Payment Method
      </h1>
      <div id="paypal-button-container" class="py-8"></div>
      <div class="flex justify-center">
        <CustomButton text="Return to Form" id="close-paypal-modal" />
      </div>
    </div>
  </div>

  {/* Thank You Modal */}
  <div
    id="thank-you-modal"
    class="
      fixed inset-0 z-1001 hidden items-center justify-center bg-black/80 p-4
    "
  >
    <div
      class="
        w-full max-w-md rounded-lg border-2 border-brand-orange bg-white p-8
        shadow-lg fade-in zoom-in-95
      "
    >
      <p class="px-4 pt-4 text-center font-body text-2xl text-black" id="thank-you-message"></p>
      <div class="mt-6 mb-4 flex justify-center">
        <button
          id="close-thank-you"
          class="
            h-10 min-w-32 rounded-full border border-black bg-transparent
            font-body text-lg font-bold text-black
            hover:bg-gray-100
          "
        >
          Ok
        </button>
      </div>
    </div>
  </div>

  {/* Snackbar for errors */}
  <div
    id="error-snackbar"
    class="
      fixed bottom-5 left-5 z-50 hidden min-w-80 items-center justify-between
      rounded-lg bg-brand-red px-6 py-3 text-white shadow-lg
    "
  >
    <span id="error-message"></span>
    <button id="close-snackbar" class="ml-4 font-bold text-white">X</button>
  </div>
</div>

<script>
  /* eslint-disable @typescript-eslint/no-explicit-any */
  import { loadScript } from '@paypal/paypal-js'

  import { PAYPAL_CONFIG, CONTACT_INFO } from '../SiteMetadata'

  function initJoinUsForm() {
    const root = document.querySelector('#join-us-form-root') as HTMLElement
    if (!root) return

    const memberships = JSON.parse(root.dataset.memberships || '[]')
    const form = document.querySelector('#join-us-form') as HTMLFormElement
    const membershipCheck = document.querySelector('#membershipCheck') as HTMLInputElement
    const countrySelect = document.querySelector('#country-select') as HTMLSelectElement
    const addressFields = document.querySelector('#address-fields') as HTMLElement
    const membershipSections = document.querySelector('#membership-sections') as HTMLElement
    const emailOnlySubmit = document.querySelector('#email-only-submit') as HTMLElement
    const donateCheck = document.querySelector('#donateCheck') as HTMLInputElement
    const donationField = document.querySelector('#donation-field') as HTMLElement
    const paymentButtonContainer = document.querySelector(
      '#payment-button-container'
    ) as HTMLElement
    const paymentNotice = document.querySelector('#payment-requirement-notice') as HTMLElement
    const continueBtn = document.querySelector('#continue-to-payment') as HTMLElement
    const submitEmailBtn = document.querySelector('#submit-email-only') as HTMLElement
    const paypalModal = document.querySelector('#paypal-modal') as HTMLElement
    const thankYouModal = document.querySelector('#thank-you-modal') as HTMLElement
    const closePaypalBtn = document.querySelector('#close-paypal-modal') as HTMLElement
    const closeThankYouBtn = document.querySelector('#close-thank-you') as HTMLElement
    const snackbar = document.querySelector('#error-snackbar') as HTMLElement
    const errorMessage = document.querySelector('#error-message') as HTMLElement
    const closeSnackbar = document.querySelector('#close-snackbar') as HTMLElement

    if (!form || !membershipCheck || !countrySelect) return

    function toggleSection(el: HTMLElement, show: boolean) {
      if (el) el.classList.toggle('hidden', !show)
    }

    membershipCheck.addEventListener('change', () => {
      toggleSection(membershipSections, !membershipCheck.checked)
      toggleSection(emailOnlySubmit, membershipCheck.checked)
      checkPaymentReady()
    })

    countrySelect.addEventListener('change', () => {
      toggleSection(addressFields, !!countrySelect.value)
      checkPaymentReady()
    })

    donateCheck.addEventListener('change', () => {
      toggleSection(donationField, donateCheck.checked)
      if (!donateCheck.checked) {
        const input = form.querySelector('[name="totalPaid"]') as HTMLInputElement
        if (input) input.value = ''
      }
      checkPaymentReady()
    })

    function checkPaymentReady() {
      const isEmailOnly = membershipCheck.checked
      let ready = true
      const required = ['fName', 'lName', 'email', 'country']
      if (countrySelect.value) {
        required.push('addressOne', 'city', 'stateLocation', 'zipcode')
      }

      for (const name of required) {
        const el = form.querySelector(`[name="${name}"]`) as HTMLInputElement
        if (!el || !el.value) ready = false
      }

      if (!isEmailOnly) {
        const newMemberEl = form.querySelector('[name="isNewMember"]') as HTMLSelectElement
        const affiliatedEl = form.querySelector('[name="affiliatedOrgs"]') as HTMLTextAreaElement
        const typeEl = document.querySelector('#membership-select') as HTMLSelectElement
        const paidEl = form.querySelector('[name="totalPaid"]') as HTMLInputElement

        if (!newMemberEl || !newMemberEl.value) ready = false
        if (!affiliatedEl || !affiliatedEl.value) ready = false
        if (!typeEl || typeEl.value === '') ready = false
        if (donateCheck.checked && (!paidEl || !paidEl.value)) ready = false
      }

      if (ready && !isEmailOnly) {
        paymentButtonContainer?.classList.remove('hidden')
        paymentNotice?.classList.add('hidden')
      } else {
        paymentButtonContainer?.classList.add('hidden')
        paymentNotice?.classList.remove('hidden')
      }
    }

    form.addEventListener('input', checkPaymentReady)
    form.addEventListener('change', checkPaymentReady)

    function showSnackBar(msg: string) {
      if (errorMessage) errorMessage.textContent = msg
      toggleSection(snackbar, true)
      setTimeout(() => hideSnackBar(), 5000)
    }

    function hideSnackBar() {
      toggleSection(snackbar, false)
    }

    closeSnackbar?.addEventListener('click', hideSnackBar)

    let isSubmitting = false

    async function handleEmailOnlySubmit(e: Event) {
      e.preventDefault()
      if (isSubmitting) return

      const formData = new FormData(form)
      const data = Object.fromEntries(formData)

      const required = [
        'fName',
        'lName',
        'email',
        'country',
        'addressOne',
        'city',
        'stateLocation',
        'zipcode'
      ]
      let hasError = false

      form
        .querySelectorAll('input, select, textarea')
        .forEach((el) => el.classList.remove('border-brand-red'))

      for (const name of required) {
        const el = form.querySelector(`[name="${name}"]`) as HTMLElement
        if (!data[name]) {
          hasError = true
          el?.classList.add('border-brand-red')
        }
      }

      if (hasError) {
        showSnackBar('Missing required fields')
        return
      }

      isSubmitting = true
      document.body.style.cursor = 'wait'

      const addressOpt = data.addressTwo ? `${data.addressTwo} ` : ''
      const givenAddress = `${data.addressOne} ${addressOpt}${data.city} ${data.stateLocation} ${data.country} ${data.zipcode}`

      try {
        const submissionData = new URLSearchParams()
        submissionData.append('form-name', 'membership')
        submissionData.append('fName', data.fName as string)
        submissionData.append('mName', data.mName as string)
        submissionData.append('lName', data.lName as string)
        submissionData.append('phone', data.phone as string)
        submissionData.append('email', data.email as string)
        submissionData.append('address', givenAddress)

        await fetch('/__forms.html', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: submissionData.toString()
        })

        const thankYouMsg = thankYouModal?.querySelector('#thank-you-message')
        if (thankYouMsg)
          thankYouMsg.textContent =
            'Thank you for your support! We will get in touch with you shortly.'
        toggleSection(thankYouModal, true)

        form.reset()
        membershipCheck.checked = false
        membershipCheck.dispatchEvent(new Event('change'))
      } catch (error: any) {
        showSnackBar(error.toString())
      } finally {
        isSubmitting = false
        document.body.style.cursor = 'default'
      }
    }

    if (submitEmailBtn) submitEmailBtn.addEventListener('click', handleEmailOnlySubmit)

    closeThankYouBtn?.addEventListener('click', () => toggleSection(thankYouModal, false))
    closePaypalBtn?.addEventListener('click', () => toggleSection(paypalModal, false))

    async function openPayPalModal() {
      const data = Object.fromEntries(new FormData(form))
      const membershipIdx = Number.parseInt(data.membershipType as string)
      const selectedMembership = memberships[membershipIdx]

      toggleSection(paypalModal, true)
      const container = document.querySelector('#paypal-button-container')
      if (container) container.innerHTML = ''

      try {
        const paypal = await loadScript({
          clientId: PAYPAL_CONFIG.CLIENT_ID,
          currency: PAYPAL_CONFIG.CURRENCY
        })

        const membershipCost = Number.parseFloat(selectedMembership.cost)
        const donationAmount = Number.parseFloat((data.totalPaid as string) || '0') || 0
        const tax = membershipCost * PAYPAL_CONFIG.TAX_RATE
        const total = membershipCost + donationAmount + tax

        const items: any[] = []
        if (membershipCost > 0) {
          items.push({
            name: selectedMembership.title,
            unit_amount: { currency_code: 'USD', value: selectedMembership.cost },
            tax: { currency_code: 'USD', value: tax.toFixed(2) },
            quantity: 1
          })
        }
        if (donationAmount > 0) {
          items.push({
            name: 'Donation',
            unit_amount: { currency_code: 'USD', value: donationAmount.toFixed(2) },
            tax: { currency_code: 'USD', value: '0.00' },
            quantity: 1
          })
        }

        if (paypal && paypal.Buttons) {
          paypal
            .Buttons({
              createOrder: (_data: any, actions: any) => {
                return actions.order.create({
                  purchase_units: [
                    {
                      amount: {
                        currency_code: 'USD',
                        value: total.toFixed(2),
                        breakdown: {
                          item_total: {
                            currency_code: 'USD',
                            value: (membershipCost + donationAmount).toFixed(2)
                          },
                          tax_total: { currency_code: 'USD', value: tax.toFixed(2) }
                        }
                      },
                      items: items
                    }
                  ]
                })
              },
              onApprove: async (_data: any, actions: any) => {
                document.body.style.cursor = 'wait'
                try {
                  const details = await actions.order.capture()
                  document.body.style.cursor = 'default'

                  const formValues = Object.fromEntries(new FormData(form))
                  const addressOpt = formValues.addressTwo ? `${formValues.addressTwo} ` : ''
                  const givenAddress = `${formValues.addressOne} ${addressOpt}${formValues.city} ${formValues.stateLocation} ${formValues.country} ${formValues.zipcode}`

                  const submissionData = new URLSearchParams()
                  submissionData.append('form-name', 'paidmembership')
                  submissionData.append(
                    'fName',
                    (formValues.fName || details.payer.name.given_name) as string
                  )
                  submissionData.append(
                    'lName',
                    (formValues.lName || details.payer.name.surname) as string
                  )
                  submissionData.append(
                    'email',
                    (formValues.email || details.payer.email_address) as string
                  )
                  submissionData.append('phone', formValues.phone as string)
                  submissionData.append('mName', formValues.mName as string)
                  submissionData.append('address', givenAddress)
                  submissionData.append(
                    'isNewMember',
                    (formValues.isNewMember === 'new').toString()
                  )
                  submissionData.append('affiliatedOrgs', formValues.affiliatedOrgs as string)
                  submissionData.append('membershipType', selectedMembership.title)
                  submissionData.append('totalPaid', details.purchase_units[0].amount.value)
                  submissionData.append(
                    'payPalTransactionId',
                    details.purchase_units[0].payments.captures[0].id
                  )

                  await fetch('/__forms.html', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: submissionData.toString()
                  })

                  toggleSection(paypalModal, false)
                  if (thankYouModal) {
                    const thankYouMsg = thankYouModal.querySelector('#thank-you-message')
                    if (thankYouMsg)
                      thankYouMsg.textContent =
                        'Thank you for your support! We will get in touch with you shortly.'
                    toggleSection(thankYouModal, true)
                  }
                  form.reset()
                  membershipCheck.checked = false
                  membershipCheck.dispatchEvent(new Event('change'))
                } catch (error: any) {
                  document.body.style.cursor = 'default'
                  if (error.details?.[0]?.issue === 'INSTRUMENT_DECLINED') return actions.restart()
                  console.error('Capture error:', error)
                  alert(
                    `Transaction completed but it wasn't sent to us. Please email us at ${CONTACT_INFO.SERVICE_EMAIL} with the receipt. Error: ${error}`
                  )
                }
              },
              onCancel: () => {
                document.body.style.cursor = 'default'
              },
              onError: (err: any) => {
                console.error(err)
                alert(
                  'An unexpected error occurred - your payment did not go through. Please try again later.'
                )
              }
            })
            .render('#paypal-button-container')
        }
      } catch (error) {
        console.error(error)
        const errorMessage = document.querySelector('#error-message')
        const snackbar = document.querySelector('#error-snackbar')
        if (errorMessage) errorMessage.textContent = 'Failed to load payment system'
        if (snackbar) snackbar.classList.remove('hidden')
      }
    }

    if (continueBtn) {
      continueBtn.addEventListener('click', (e) => {
        e.preventDefault()
        openPayPalModal()
      })
    }
  }

  initJoinUsForm()
  document.addEventListener('astro:page-load', initJoinUsForm)
</script>

<style>
  #paypal-modal:not(.hidden),
  #thank-you-modal:not(.hidden),
  #error-snackbar:not(.hidden) {
    display: flex !important;
  }
  .fade-in {
    animation: fadeIn 0.5s ease-in-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .zoom-in-95 {
    transform: scale(0.95);
  }
  .slide-in-from-top-4 {
    transform: translateY(-1rem);
    animation: slideInFromTop 0.5s ease-out forwards;
  }
  @keyframes slideInFromTop {
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
