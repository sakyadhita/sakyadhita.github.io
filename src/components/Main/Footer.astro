---
/**
 * Renders the responsive Footer component for the general website. Footer is coded to display after end of all content,
 * but is not guranteed to be always at the bottom of the page for small content pages.
 *
 * This component has no dependencies, and works independently.
 *
 * @author Amrit Kaur Singh
 */
import { siFacebook, siYoutube, siPinterest, siRss, siGoodreads } from 'simple-icons'
import SimpleIcon from './SimpleIcon'
import Brand from './Brand.astro'
import Logo from '../../media/logo.svg'
import { SITE_PAGES } from '../../constants/links'
import { cn } from '../../lib/utils'

const FACEBOOK_LINK = 'https://www.facebook.com/sakyadhita.international'
const YOUTUBE_LINK = 'https://www.youtube.com/channel/UCLOIc4vqaqPKcjaRqmn6-yg/playlists'
const PINTEREST_LINK = 'https://www.pinterest.com/sakyadhita/'
const ABW_BLOG_LINK = 'http://awakeningbuddhistwomen.blogspot.com/'
const GOODREADS_LINK = 'https://www.goodreads.com/group/show/94269-women-in-buddhism'

const socialIconClasses = 'w-10 h-10 md:w-12 md:h-12 lg:w-16 lg:h-16 transition-all shrink-0'
---

<div class="relative mt-auto">
  {/* Background Image Layer */}
  <div
    class="absolute inset-0 z-[-1] w-full h-full bg-cover bg-[position:center,top] bg-no-repeat blur-[5px] rounded-md shadow-[inset_0_0_0_1000px_rgba(26,23,194,0.4)]"
    style={{
      backgroundImage:
        'url("https://images.unsplash.com/photo-1434725039720-aaad6dd32dfe?ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&ixlib=rb-1.2.1&auto=format&fit=crop&w=2996&q=80")'
    }}
  >
  </div>

  <div
    class="relative z-0 bg-brand-light-purple/90 w-full min-h-[550px] flex flex-col justify-center items-center px-6 md:px-20 py-10 md:py-16 overflow-hidden font-body"
  >
    {/* Pages Links */}
    <section class="w-full flex flex-col md:flex-row justify-between flex-1 space-y-8 md:space-y-0">
      <div class="flex flex-col">
        <a
          href={SITE_PAGES.HOME}
          class="font-heading font-bold text-lg md:text-2xl text-white capitalize hover:no-underline mb-2 block"
        >
          Home
        </a>
        <div class="flex flex-col ml-1 md:ml-0">
          <a
            href={SITE_PAGES.JOIN_US}
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            Join Us
          </a>
          <a
            href={SITE_PAGES.VOLUNTEER}
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            Volunteer
          </a>
          <a
            href={SITE_PAGES.DONATE}
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            Donate
          </a>
        </div>
      </div>

      <div class="flex flex-col text-left">
        <a
          href={SITE_PAGES.CONFERENCES}
          class="font-heading font-bold text-lg md:text-2xl text-white capitalize hover:no-underline mb-2 block"
        >
          Conferences
        </a>
        <div class="flex flex-col ml-1 md:ml-0">
          <a
            href="/conferences/19"
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            2025 19th conference, (Sarawak, Malaysia)
          </a>
          <a
            href="/conferences/18"
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            2023 18th conference, (Seoul, Korea)
          </a>
          <a
            href="/conferences/17"
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            2021 17th conference, (online)
          </a>
          <a
            href="/conferences/16"
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            2019 16th conference, (Blue Mountains, Australia)
          </a>
        </div>
      </div>

      <div class="flex flex-col">
        <a
          href={SITE_PAGES.RESOURCES_LANDING}
          class="font-heading font-bold text-lg md:text-2xl text-white capitalize hover:no-underline mb-2 block"
        >
          Resources
        </a>
        <div class="flex flex-col ml-1 md:ml-0">
          <a
            href={SITE_PAGES.RESOURCES_NEWSLETTERS}
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            Newsletters
          </a>
          <a
            href={SITE_PAGES.RESOURCES_EPUBS}
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            Publications
          </a>
          <a
            href={SITE_PAGES.RESOURCES_BUDDHIST_CULTURE}
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            Buddhist Culture
          </a>
          <a
            href={SITE_PAGES.RESOURCES_ORDINATION_ISSUE}
            class="text-xs md:text-sm text-[#cee5ec] hover:text-brand-orange transition-colors flex items-center mt-1"
          >
            <img src={Logo.src} alt="Logo" class="w-5 h-auto mr-2" />
            Ordination
          </a>
        </div>
      </div>

      <div>
        <a
          href={SITE_PAGES.ABOUT_US}
          class="font-heading font-bold text-lg md:text-2xl text-white capitalize hover:no-underline mb-2 block"
        >
          About
        </a>
      </div>

      <div>
        <a
          href={SITE_PAGES.CONTACT_US}
          class="font-heading font-bold text-lg md:text-2xl text-white capitalize hover:no-underline mb-2 block"
        >
          Contact
        </a>
      </div>
    </section>

    {/* Bottom Section: Social Media & Brand */}
    <section
      class="w-full flex flex-col md:flex-row justify-between items-center mt-12 space-y-8 md:space-y-0"
    >
      <div class="flex flex-col items-center md:items-start text-white">
        <span class="mb-4 text-lg md:text-xl font-bold"> Check us out on these platforms! </span>
        <div class="flex flex-row space-x-6">
          <a
            href={FACEBOOK_LINK}
            target="_blank"
            rel="noreferrer"
            class="group transition-transform hover:scale-110"
          >
            <SimpleIcon
              icon={siFacebook}
              className={cn(socialIconClasses, 'text-white group-hover:bg-[#3b5998] p-1')}
            />
          </a>
          <a
            href={YOUTUBE_LINK}
            target="_blank"
            rel="noreferrer"
            class="group transition-transform hover:scale-110"
          >
            <SimpleIcon
              icon={siYoutube}
              className={cn(
                socialIconClasses,
                'text-white group-hover:bg-[#c4302b] rounded-xl p-1'
              )}
            />
          </a>
          <a
            href={PINTEREST_LINK}
            target="_blank"
            rel="noreferrer"
            class="group transition-transform hover:scale-110"
          >
            <SimpleIcon
              icon={siPinterest}
              className={cn(
                socialIconClasses,
                'text-white group-hover:bg-[#E60023] rounded-2xl p-2'
              )}
            />
          </a>
          <a
            href={ABW_BLOG_LINK}
            target="_blank"
            rel="noreferrer"
            class="group transition-transform hover:scale-110"
          >
            <SimpleIcon
              icon={siRss}
              className={cn(socialIconClasses, 'text-white group-hover:text-brand-orange p-1')}
            />
          </a>
          <a
            href={GOODREADS_LINK}
            target="_blank"
            rel="noreferrer"
            class="group transition-transform hover:scale-110"
          >
            <SimpleIcon
              icon={siGoodreads}
              className={cn(socialIconClasses, 'text-white group-hover:text-[#e9e5cd] p-1')}
            />
          </a>
        </div>
      </div>

      <Brand location="footer" />
    </section>

    <div
      class="mt-12 w-full border-t border-white/20 pt-8 text-white text-center text-sm md:text-base font-body"
    >
      <img width={64} src="/by-nc-nd.png" alt="license" class="inline-block mb-2 md:mb-0" />
      <span class="block md:inline-block md:ml-2">
        Website is licensed under a
        <a
          target="_blank"
          rel="noreferrer"
          href="https://creativecommons.org/licenses/by-nc-nd/4.0/"
          class="hover:text-brand-orange transition-colors mx-1"
        >
          Creative Commons Attribution-NonCommercial-NoDerivs 4.0 International License
        </a>
        .
      </span>
    </div>
  </div>
</div>
