---
/**
 * Renders the global Footer for the website.
 *
 * @summary Global footer component.
 * @author Amrit Kaur Singh
 */
import { Image } from 'astro:assets'

import Logo from '../../assets/logo.svg'
import { SITE_PAGES, SOCIAL_LINKS } from '../../SiteMetadata'

const currentYear = new Date().getFullYear()

// Common link classes
const linkClass = 'hover:text-brand-orange transition-colors'
const sectionTitleClass = 'font-heading font-bold text-xl mb-6 text-black'
const listClass = 'space-y-4'
---

<footer class="w-full bg-[#f7f7f7] py-16 text-gray-700">
  <div class="
    mx-auto max-w-7xl px-6
    md:px-12
  ">
    <div class="
      grid grid-cols-1 gap-12
      lg:grid-cols-4
    ">
      {/* Brand Section */}
      <div class="space-y-6">
        <div class="flex items-center space-x-3">
          <Image src={Logo} alt="Sakyadhita Logo" class="size-12" />
          <span class="
            font-heading text-2xl font-bold tracking-tight text-black italic
          ">
            sakyadhita
          </span>
        </div>
        <p class="font-body text-sm/relaxed leading-relaxed">
          The Sakyadhita International Association of Buddhist Women is an alliance of women around
          the world.
        </p>
        <div class="flex space-x-5">
          <a
            href={SOCIAL_LINKS.FACEBOOK}
            target="_blank"
            rel="noopener noreferrer"
            class="
              text-gray-400
              hover:text-[#1877F2]
            "
            aria-label="Facebook"
          >
            <svg class="size-6 fill-current" viewBox="0 0 24 24">
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path>
            </svg>
          </a>
          <a
            href={SOCIAL_LINKS.YOUTUBE}
            target="_blank"
            rel="noopener noreferrer"
            class="
              text-gray-400
              hover:text-[#FF0000]
            "
            aria-label="YouTube"
          >
            <svg class="size-6 fill-current" viewBox="0 0 24 24">
              <path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.016 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      {/* Explore Section */}
      <div>
        <h3 class={sectionTitleClass}>Explore</h3>
        <ul class={listClass}>
          <li>
            <a href={SITE_PAGES.HOME} class="
              flex items-center text-black no-underline
            ">
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Home</span>
            </a>
          </li>
          <li>
            <a href={SITE_PAGES.ABOUT_US} class="
              flex items-center text-black no-underline
            ">
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>About Us</span>
            </a>
          </li>
          <li>
            <a href={SITE_PAGES.CONFERENCES} class="
              flex items-center text-black no-underline
            ">
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Conferences</span>
            </a>
          </li>
        </ul>
      </div>

      {/* Resources Section */}
      <div>
        <h3 class={sectionTitleClass}>Resources</h3>
        <ul class={listClass}>
          <li>
            <a
              href={SITE_PAGES.RESOURCES_LANDING}
              class="flex items-center text-black no-underline"
            >
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Library</span>
            </a>
          </li>
          <li>
            <a
              href={SITE_PAGES.RESOURCES_NEWSLETTERS}
              class="flex items-center text-black no-underline"
            >
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Newsletters</span>
            </a>
          </li>
          <li>
            <a href={SITE_PAGES.RESOURCES_EPUBS} class="
              flex items-center text-black no-underline
            ">
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>E-Publications</span>
            </a>
          </li>
          <li>
            <a
              href={SITE_PAGES.RESOURCES_BUDDHIST_CULTURE}
              class="flex items-center text-black no-underline"
            >
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Buddhist Culture</span>
            </a>
          </li>
          <li>
            <a
              href={SITE_PAGES.RESOURCES_ORDINATION_ISSUE}
              class="flex items-center text-black no-underline"
            >
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Ordination Issue</span>
            </a>
          </li>
        </ul>
      </div>

      {/* Contact Section */}
      <div>
        <h3 class={sectionTitleClass}>Connect</h3>
        <ul class={listClass}>
          <li>
            <a href={SITE_PAGES.CONTACT_US} class="
              flex items-center text-black no-underline
            ">
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Contact Us</span>
            </a>
          </li>
          <li>
            <a href={SITE_PAGES.JOIN_US} class="
              flex items-center text-black no-underline
            ">
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Join Us</span>
            </a>
          </li>
          <li>
            <a href={SITE_PAGES.VOLUNTEER} class="
              flex items-center text-black no-underline
            ">
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Volunteer</span>
            </a>
          </li>
          <li>
            <a href={SITE_PAGES.DONATE} class="
              flex items-center text-black no-underline
            ">
              <Image src={Logo} alt="Logo" class="mr-2 h-auto w-5" />
              <span class={linkClass}>Donate</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="mt-16 border-t border-gray-200 pt-8">
      <div class="
        flex flex-col items-center justify-between gap-4
        md:flex-row
      ">
        <p class="font-body text-sm text-gray-500">
          © {currentYear} Sakyadhita International Association of Buddhist Women.
        </p>
        <div class="flex space-x-6 text-sm">
          <a
            href={SOCIAL_LINKS.FACEBOOK}
            class="
              text-gray-500
              hover:text-brand-orange
            "
            target="_blank"
            rel="noopener noreferrer"
          >
            Facebook
          </a>
          <a
            href={SOCIAL_LINKS.YOUTUBE}
            class="
              text-gray-500
              hover:text-brand-orange
            "
            target="_blank"
            rel="noopener noreferrer"
          >
            YouTube
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
