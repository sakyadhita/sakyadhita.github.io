---
/**
 * Sticky Navbar for all pages. Contains the Sakyadhita logo, branding, and a
 * hamburger icon to expand the navigation panel.
 */
import { Icon } from 'astro-icon/components'
import Brand from '../Brand.astro'
import { SITE_PAGES } from '../../../constants/links'

const navLinks = [
  { label: 'Home', link: SITE_PAGES.HOME },
  { label: 'Conferences', link: SITE_PAGES.CONFERENCES },
  { label: 'Resources', link: SITE_PAGES.RESOURCES_LANDING },
  { label: 'About Us', link: SITE_PAGES.ABOUT_US },
  { label: 'Contact Us', link: SITE_PAGES.CONTACT_US }
]

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
---

<nav class="sticky top-0 z-1000 w-full" id="main-nav">
  <!-- The actual Navigation Bar -->
  <div
    class="
      flex h-12 w-full items-center justify-between bg-brand-light-purple
      px-6 py-2 text-white shadow-none
      md:h-32 md:px-14 md:py-4 md:shadow-[0px_3px_6px_rgba(0,0,0,0.16)]
    "
  >
    <!-- Logo and Branding -->
    <Brand />

    <!-- Hamburger Button to Toggle Navigation -->
    <button
      type="button"
      id="nav-toggle"
      class="
        relative size-5 cursor-pointer border-none bg-transparent
        md:size-12
      "
      aria-label="Toggle Navigation"
    >
      <Icon name="lucide:menu" class="size-full" id="menu-icon" />
    </button>
  </div>

  <!-- Navigation Panel -->
  <div
    id="nav-panel"
    class="
      fixed top-0 right-[-100vw] z-1001 flex size-full flex-col
      justify-start overflow-y-auto bg-brand-orange pt-16 transition-[right]
      duration-500 ease-in-out
      md:top-32 md:right-[-320px] md:h-[calc(100vh-128px)] md:w-80
      md:justify-between md:pt-0
    "
  >
    <!-- Cross icon to close panel on mobile -->
    <button
      type="button"
      id="nav-close"
      class="
        absolute top-6 right-6 size-6 cursor-pointer border-none
        bg-transparent
        md:hidden
      "
      aria-label="Close Navigation"
    >
      <Icon name="lucide:x" class="w-full" />
    </button>

    <!-- Nav Links -->
    <div
      class="
        flex size-full flex-col
        md:h-auto
      "
    >
      {
        navLinks.map((item) => {
          const isActive =
            currentPath === (item.link.replace(/\/$/, '') || '/')
              ? 'bg-brand-dark-orange'
              : ''
          return (
            <a
              href={item.link}
              class={`
                w-full h-16 md:h-24 flex justify-start items-center pl-10 md:pl-8 
                hover:bg-brand-dark-orange hover:no-underline transition-colors group
                ${isActive}
              `}
            >
              <span class="font-heading text-lg text-white lowercase md:text-xl">
                {item.label}
              </span>
            </a>
          )
        })
      }
    </div>
  </div>

  <!-- Overlay to darken website content when toggled -->
  <div
    id="nav-overlay"
    class="
      pointer-events-none fixed inset-0 z-999 hidden bg-black/30 opacity-0
      backdrop-blur-[2px] transition-opacity duration-500
      md:block
    "
    aria-label="Close navigation overlay"
  >
  </div>
</nav>

<script>
  const nav = document.querySelector('#main-nav')
  const toggle = document.querySelector('#nav-toggle')
  const close = document.querySelector('#nav-close')
  const panel = document.querySelector('#nav-panel')
  const overlay = document.querySelector('#nav-overlay')

  function toggleNav() {
    const isVisible = panel?.classList.contains('right-0')

    if (isVisible) {
      panel?.classList.remove('right-0')
      overlay?.classList.add('opacity-0', 'pointer-events-none')
      overlay?.classList.remove('opacity-100', 'pointer-events-auto')
    } else {
      panel?.classList.add('right-0')
      overlay?.classList.remove('opacity-0', 'pointer-events-none')
      overlay?.classList.add('opacity-100', 'pointer-events-auto')
    }
  }

  toggle?.addEventListener('click', toggleNav)
  close?.addEventListener('click', toggleNav)
  overlay?.addEventListener('click', toggleNav)

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel?.classList.contains('right-0')) {
      toggleNav()
    }
  })
</script>

<style>
  /* Use class based visibility for the panel */
  #nav-panel.right-0 {
    right: 0 !important;
  }
</style>
