---
/**
 * Additional Navbar rendered only for the Resources page.
 * Active link detection uses Astro.url.pathname (server-rendered).
 * Mobile drawer toggle handled via a lightweight inline script.
 *
 * @summary     Additional Navbar for the Resources page.
 * @author      Aaron Kirk
 */
import { Icon } from 'astro-icon/components'

import { SITE_PAGES } from '../../SiteMetadata'

const navItems = [
  { label: 'resources', link: SITE_PAGES.RESOURCES_LANDING },
  { label: 'newsletters', link: SITE_PAGES.RESOURCES_NEWSLETTERS },
  { label: 'publications', link: SITE_PAGES.RESOURCES_EPUBS },
  { label: 'buddhist culture', link: SITE_PAGES.RESOURCES_BUDDHIST_CULTURE },
  { label: 'ordination issue', link: SITE_PAGES.RESOURCES_ORDINATION_ISSUE }
]

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/'

function isActive(link: string) {
  return (link.replace(/\/+$/, '') || '/') === currentPath
}

const mobileItemClasses =
  'w-full h-16 flex justify-start items-center px-10 sm:px-20 hover:bg-brand-dark-orange transition-colors no-underline hover:no-underline'
const desktopItemClasses =
  'w-48 h-full flex items-center justify-center text-white font-body text-lg hover:bg-brand-dark-orange transition-colors no-underline hover:no-underline lowercase'
const textClasses = 'font-heading text-white text-lg lowercase'
---

{/* Button to toggle mobile drawer */}
<button
  id="resources-menu-toggle"
  type="button"
  class="fixed top-20 left-5 z-1001 flex size-10 cursor-pointer items-center
    justify-center rounded-full border-none bg-brand-orange shadow-lg
    md:hidden"
  aria-label="Toggle Resources Menu"
>
  <span class="text-xs font-bold text-white uppercase">Menu</span>
</button>

{/* Mobile Drawer */}
<div
  id="resources-mobile-drawer"
  class="fixed top-0 right-0 z-1002 flex size-full translate-x-full flex-col
    bg-brand-orange pt-20 transition-transform duration-500
    md:hidden"
>
  <button
    id="resources-drawer-close"
    type="button"
    class="absolute top-6 right-6 size-6 cursor-pointer border-none bg-transparent"
    aria-label="Close Resources Navigation"
  >
    <Icon name="lucide:x" class="size-full text-white" />
  </button>

  <nav class="flex flex-col">
    {
      navItems.map((item) => (
        <a
          href={item.link}
          class:list={[mobileItemClasses, { 'bg-brand-dark-orange': isActive(item.link) }]}
        >
          <span class={textClasses}>{item.label}</span>
        </a>
      ))
    }
  </nav>
</div>

{/* Desktop Horizontal Navbar */}
<nav
  id="resources-desktop-nav"
  class="sticky top-32 z-999 hidden h-20 w-full items-center justify-center
    bg-brand-orange shadow-md
    md:flex"
>
  {
    navItems.map((item) => (
      <a
        href={item.link}
        class:list={[desktopItemClasses, { 'bg-brand-dark-orange': isActive(item.link) }]}
      >
        {item.label}
      </a>
    ))
  }
</nav>

{/* Page content */}
<main class="relative z-0">
  <slot />
</main>

<script>
  const toggleBtn = document.querySelector('#resources-menu-toggle')
  const closeBtn = document.querySelector('#resources-drawer-close')
  const drawer = document.querySelector('#resources-mobile-drawer')

  function openDrawer() {
    drawer?.classList.replace('translate-x-full', 'translate-x-0')
  }

  function closeDrawer() {
    drawer?.classList.replace('translate-x-0', 'translate-x-full')
  }

  toggleBtn?.addEventListener('click', openDrawer)
  closeBtn?.addEventListener('click', closeDrawer)
</script>
