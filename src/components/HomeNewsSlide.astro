---
import CustomButton from './CustomButton.astro'

/**
 * News & Events slide screen is for usage in Home page's slideshow component.
 * This formats exactly one slide, with display information passed as props.
 */
interface Props {
  title?: string
  description?: string
  image_url: string | ImageMetadata
  redirect_link?: string
  showButton?: boolean
  openInSameTab?: boolean
  height?: string
}

const {
  title,
  description,
  image_url,
  redirect_link,
  showButton = false,
  openInSameTab = false,
  height = '100%'
} = Astro.props

const imageUrl = typeof image_url === 'string' ? image_url : image_url.src
---

<div
  class="
    embla__slide w-full bg-[no-repeat,no-repeat] bg-size-[cover,contain]
    bg-position-[center,top]
  "
  style={{ backgroundImage: `url("${imageUrl}")`, height }}
>
  {/* Displays all slide information in rectangular box */}
  <div
    class="
      absolute top-[7%] left-[15%] h-fit w-[70.5vw] bg-brand-dark-purple/20 p-8
      text-white
      md:left-1/2 md:w-lg md:-translate-x-1/2
      lg:left-[15%] lg:translate-x-0 lg:p-12
    "
  >
    {/* Title */}
    {
      title && (
        <h1
          class="
            mb-5 font-heading text-2xl font-bold
            lg:text-3xl
          "
        >
          {title}
        </h1>
      )
    }
    {/* Description */}
    {
      description && (
        <p
          class="
            mb-5 text-sm
            lg:text-base
          "
        >
          {description}
        </p>
      )
    }
    {/* Button */}
    {
      showButton && redirect_link && (
        <CustomButton
          openInSameTab={openInSameTab}
          redirect_link={redirect_link}
          text="Learn More"
        />
      )
    }
  </div>
</div>
