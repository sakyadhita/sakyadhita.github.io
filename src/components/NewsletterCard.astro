---
/**
 * Renders a newsletter Card given information about that newsletter.
 *
 * @author PatrickBrown1 (Migrated to Astro by Gemini CLI)
 */
import { Image } from 'astro:assets'

import { getAssetUrl } from '../lib'

import type { ImageMetadata } from 'astro'

interface Props {
  title: string
  year: number | string
  image: ImageMetadata
  pdfLink: any
}

const { title, year, image, pdfLink } = Astro.props
const resolvedPdfLink = getAssetUrl(pdfLink)
---

<div class="
  newsletter-card group m-4 inline-block w-60
  sm:m-5 sm:w-64
  md:m-6 md:size-72
">
  <a
    href={resolvedPdfLink}
    target="_blank"
    rel="noreferrer noopener"
    class="
      text-black no-underline
      hover:no-underline
    "
  >
    <Image
      alt={title}
      src={image}
      width={300}
      height={400}
      loading="lazy"
      decoding="async"
      class="
        mb-3 h-48 w-full object-cover shadow-card transition-all
        group-hover:scale-105 group-hover:shadow-card-hover
        sm:mb-4 sm:h-52
        md:mb-2.5 md:h-60
      "
    />
    <span class="
      block h-5 text-left font-body text-sm/5 text-black
      sm:text-base/6
      md:text-base/5
    ">
      {year}
    </span>
    <span
      class="
        mt-1 block h-7 overflow-hidden text-left font-body text-base/6 text-wrap
        text-black
        sm:text-xl/7
        md:text-xl/7
      "
    >
      {title}
    </span>
  </a>
</div>
