---
import { Icon } from 'astro-icon/components'

import type { ConferenceEntry } from '../../lib/types'

interface Props {
  title: string
  info: ConferenceEntry
}

const { title, info } = Astro.props
const items = info.data
---

<div class="fade-in slide-in-from-bottom-4 w-full animate-in space-y-10">
  {/* The title of the conference */}
  <section class="space-y-6">
    <h1
      class="
        max-w-2xl font-heading text-3xl font-bold tracking-tight
        text-brand-dark-purple lowercase
        md:text-5xl
      "
    >
      {title}
    </h1>
  </section>

  {/* Header section for file downloads */}
  <section class="max-w-md">
    <h4
      class="
        mb-8 border-l-4 border-brand-orange pl-4 font-heading text-xl/relaxed
        font-bold text-gray-600 lowercase italic
      "
    >
      Conference resources are available for download as a PDF.
    </h4>
  </section>

  <div class="
    flex flex-col gap-8
    lg:flex-row lg:gap-12
  ">
    <div class="max-w-md flex-1 space-y-2">
      {/* brochures */}
      <div
        class="
          mb-3 bg-brand-orange p-1 px-2 font-body text-sm font-bold
          tracking-widest text-white uppercase
        "
      >
        Brochures
      </div>
      <div class="mb-8 flex flex-col space-y-2">
        {
          !items.brochures || items.brochures.length === 0 ? (
            <div
              class="
                rounded-lg border border-dashed border-gray-200 px-4 py-2
                text-gray-400 italic
              "
            >
              No info available
            </div>
          ) : (
            items.brochures.map((program) => (
              <a
                href={program.url}
                download
                class="
                  group flex w-full items-center space-x-3 rounded-xl border
                  border-gray-100 bg-gray-50 p-3 no-underline transition-all
                  hover:bg-brand-orange/10 hover:text-brand-orange
                  hover:no-underline
                  md:w-[307.2px]
                "
              >
                <Icon
                  name="lucide:download"
                  class="
                    size-5 text-brand-dark-purple
                    group-hover:text-brand-orange
                  "
                />
                <span class="font-body font-medium">{program.description}</span>
              </a>
            ))
          )
        }
      </div>

      {/* programs */}
      <div
        class="
          mb-3 bg-brand-orange p-1 px-2 font-body text-sm font-bold
          tracking-widest text-white uppercase
        "
      >
        Programs
      </div>
      <div class="mb-8 flex flex-col space-y-2">
        {
          !items.programs || items.programs.length === 0 ? (
            <div
              class="
                rounded-lg border border-dashed border-gray-200 px-4 py-2
                text-gray-400 italic
              "
            >
              No info available
            </div>
          ) : (
            items.programs.map((program) => (
              <a
                href={program.url}
                download
                class="
                  group flex w-full items-center space-x-3 rounded-xl border
                  border-gray-100 bg-gray-50 p-3 no-underline transition-all
                  hover:bg-brand-orange/10 hover:text-brand-orange
                  hover:no-underline
                  md:w-[307.2px]
                "
              >
                <Icon
                  name="lucide:download"
                  class="
                    size-5 text-brand-dark-purple
                    group-hover:text-brand-orange
                  "
                />
                <span class="font-body font-medium">{program.description}</span>
              </a>
            ))
          )
        }
      </div>

      {/* abstracts */}
      <div
        class="
          mb-3 bg-brand-orange p-1 px-2 font-body text-sm font-bold
          tracking-widest text-white uppercase
        "
      >
        Abstracts
      </div>
      <div class="mb-8 flex flex-col space-y-2">
        {
          !items.abstracts || items.abstracts.length === 0 ? (
            <div
              class="
                rounded-lg border border-dashed border-gray-200 px-4 py-2
                text-gray-400 italic
              "
            >
              No info available
            </div>
          ) : (
            items.abstracts.map((program) => (
              <a
                href={program.url}
                download
                class="
                  group flex w-full items-center space-x-3 rounded-xl border
                  border-gray-100 bg-gray-50 p-3 no-underline transition-all
                  hover:bg-brand-orange/10 hover:text-brand-orange
                  hover:no-underline
                  md:w-[307.2px]
                "
              >
                <Icon
                  name="lucide:download"
                  class="
                    size-5 text-brand-dark-purple
                    group-hover:text-brand-orange
                  "
                />
                <span class="font-body font-medium">{program.description}</span>
              </a>
            ))
          )
        }
      </div>

      {/* presentations */}
      <div
        class="
          mb-3 bg-brand-orange p-1 px-2 font-body text-sm font-bold
          tracking-widest text-white uppercase
        "
      >
        Presentations
      </div>
      <div class="mb-8 flex flex-col space-y-2">
        {
          !items.presentations || items.presentations.length === 0 ? (
            <div
              class="
                rounded-lg border border-dashed border-gray-200 px-4 py-2
                text-gray-400 italic
              "
            >
              No info available
            </div>
          ) : (
            items.presentations.map((program) => (
              <a
                href={program.url}
                download
                class="
                  group flex w-full items-center space-x-3 rounded-xl border
                  border-gray-100 bg-gray-50 p-3 no-underline transition-all
                  hover:bg-brand-orange/10 hover:text-brand-orange
                  hover:no-underline
                  md:w-[307.2px]
                "
              >
                <Icon
                  name="lucide:download"
                  class="
                    size-5 text-brand-dark-purple
                    group-hover:text-brand-orange
                  "
                />
                <span class="font-body font-medium">{program.description}</span>
              </a>
            ))
          )
        }
      </div>
    </div>

    <div class="
      shrink-0
      lg:w-1/2
    ">
      <slot name="slideshow" />
    </div>
  </div>
</div>
