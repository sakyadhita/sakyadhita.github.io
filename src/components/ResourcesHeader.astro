---
/**
 * This file creates a component for the resources header with an image, title, and description text.
 *
 * @summary Creates a component for resources header
 * @author Dhanush Nanjunda Reddy, Amrit Kaur Singh
 */
import { getImage } from 'astro:assets'

import { cn } from '../lib/utils'

interface Props {
  image?: string | ImageMetadata
  title?: string
  text?: string
  class?: string
}

const { image, title, text, class: className } = Astro.props

const optimizedImage =
  typeof image === 'string'
    ? null
    : image
      ? await getImage({ src: image, format: 'webp', width: 1600 })
      : null

const imageUrl = optimizedImage?.src || (typeof image === 'string' ? image : image ? image.src : '')
---

<div
  class={cn(
    `
      relative min-h-[max(40vh,300px)] w-full bg-cover bg-position-[center,top]
      bg-no-repeat
      sm:min-h-[max(75vh,400px)]
    `,
    className
  )}
  style={{ backgroundImage: imageUrl ? `url("${imageUrl}")` : 'none' }}
>
  {/* Purple box with a title and description */}
  <div
    class="
      absolute top-8 mt-[10%] ml-[7vw] h-fit w-2/3 bg-brand-dark-purple/90 p-8
      text-white
      sm:top-0 sm:ml-[10%] sm:w-lg
    "
  >
    {
      title && (
        <h1
          class="
            mt-4 ml-6 w-full font-heading text-2xl/relaxed font-bold
            sm:mt-0 sm:ml-0 sm:text-4xl
          "
        >
          {title}
        </h1>
      )
    }
    {
      text && (
        <p
          class="
            mt-4 hidden font-body text-lg/relaxed font-normal
            sm:block
          "
        >
          {text}
        </p>
      )
    }
  </div>
</div>
