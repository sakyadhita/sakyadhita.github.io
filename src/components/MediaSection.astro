---
import { Icon } from 'astro-icon/components'

import MediaCard from './MediaCard.astro'

import type { CollectionEntry } from 'astro:content'

interface Props {
  section_title: string
  section_list: CollectionEntry<'publication'>[]
}

const { section_title, section_list } = Astro.props
---

<div class="media-section relative mx-auto max-w-7xl px-6 py-12" data-section-title={section_title}>
  {/* Header */}
  <div class="
    relative flex w-full flex-col
    lg:h-12 lg:flex-row lg:items-center lg:justify-between
  ">
    <h1
      class="
        w-full text-center font-heading text-2xl font-bold lowercase
        sm:text-4xl
        lg:text-left
      "
    >
      {section_title}
    </h1>
    <button
      type="button"
      class="
        section-toggle z-20 mx-auto mt-4 mb-8 w-fit cursor-pointer border-none
        bg-inherit p-0 text-center font-body text-base/tight no-underline
        hover:underline
        lg:absolute lg:right-6 lg:bottom-0 lg:mb-4 lg:text-lg/relaxed
      "
      data-section={section_title}
    >
      All <span class="text-brand-orange">({section_list.length})</span>
      <span class="lg:inline">&gt;</span>
    </button>
  </div>

  {/* Desktop Content (Static) */}
  <div class="
    relative -mx-6 hidden flex-wrap items-start justify-center text-center
    lg:flex
  ">
    {
      section_list
        .slice(0, 5)
        .map((pub) => (
          <MediaCard
            title={pub.data.title}
            subtitle={pub.data.author}
            image={pub.data.imageLink}
            pdfLink={pub.data.pdfLink}
          />
        ))
    }
  </div>

  {/* Mobile Content (Carousel) */}
  <div
    class="
      relative -mx-6 flex flex-wrap items-start justify-center overflow-hidden
      text-center
      lg:hidden
    "
  >
    <button
      type="button"
      class="
        prev-btn relative bottom-48 m-0 inline-block size-8 cursor-pointer
        border-none bg-inherit
        disabled:invisible
      "
    >
      <Icon name="lucide:chevron-left" class="size-full" />
    </button>

    <div class="mobile-card-container">
      {
        section_list.map((pub, index) => (
          <div class={index === 0 ? 'block' : 'hidden'} data-index={index}>
            <MediaCard
              title={pub.data.title}
              subtitle={pub.data.author}
              image={pub.data.imageLink}
              pdfLink={pub.data.pdfLink}
            />
          </div>
        ))
      }
    </div>

    <button
      type="button"
      class="
        next-btn relative bottom-48 m-0 inline-block size-8 cursor-pointer
        border-none bg-inherit
        disabled:invisible
      "
    >
      <Icon name="lucide:chevron-right" class="size-full" />
    </button>
  </div>

  <div class="
    absolute inset-x-6 bottom-0 h-px bg-brand-orange
    lg:h-2
  "></div>
</div>

<script>
  function initMediaSections() {
    const sections = document.querySelectorAll('.media-section')
    sections.forEach((section) => {
      let currentIndex = 0
      const list = section.querySelectorAll('.mobile-card-container > div')
      const prevBtn = section.querySelector('.prev-btn') as HTMLButtonElement
      const nextBtn = section.querySelector('.next-btn') as HTMLButtonElement

      const updateMobileView = () => {
        list.forEach((item, index) => {
          if (index === currentIndex) {
            item.classList.remove('hidden')
            item.classList.add('block')
          } else {
            item.classList.remove('block')
            item.classList.add('hidden')
          }
        })

        if (prevBtn) prevBtn.disabled = currentIndex === 0
        if (nextBtn) nextBtn.disabled = currentIndex === list.length - 1
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          if (currentIndex > 0) {
            currentIndex--
            updateMobileView()
          }
        })
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          if (currentIndex < list.length - 1) {
            currentIndex++
            updateMobileView()
          }
        })
      }

      updateMobileView()
    })
  }

  initMediaSections()
  document.addEventListener('astro:page-load', initMediaSections)
</script>
