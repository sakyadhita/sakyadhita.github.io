---
import { Icon } from 'astro-icon/components'

import { getAssetUrl } from '../lib'

import type { CollectionEntry } from 'astro:content'

interface Props {
  title: string
  info: CollectionEntry<'conference'>
}

const { title, info } = Astro.props
const items = info.data

const resolveList = (list?: any[]) =>
  list ? list.map((i) => ({ ...i, url: getAssetUrl(i.url) })) : []

const resources = [
  { title: 'Brochures', data: resolveList(items.brochures) },
  { title: 'Programs', data: resolveList(items.programs) },
  { title: 'Abstracts', data: resolveList(items.abstracts) },
  { title: 'Presentations', data: resolveList(items.presentations) }
]
---

<div class="w-full space-y-10 animate-in fade-in slide-in-from-bottom-4">
  {/* The title of the conference */}
  <section class="space-y-6">
    <h1
      class="
        max-w-2xl font-heading text-3xl font-bold tracking-tight
        text-brand-dark-purple lowercase
        md:text-5xl
      "
    >
      {title}
    </h1>
  </section>

  {/* Header section for file downloads */}
  <section class="max-w-md">
    <h4
      class="
        mb-8 border-l-4 border-brand-orange pl-4 font-heading text-xl/relaxed
        font-bold text-gray-600 lowercase italic
      "
    >
      Conference resources are available for download as a PDF.
    </h4>
  </section>

  <div class="
    flex flex-col gap-8
    lg:flex-row lg:gap-12
  ">
    <div class="max-w-md flex-1 space-y-2">
      {
        resources.map((section) => (
          <>
            <div class="
              mb-3 bg-brand-orange p-1 px-2 font-body text-sm font-bold
              tracking-widest text-white uppercase
            ">
              {section.title}
            </div>
            <div class="mb-8 flex flex-col space-y-2">
              {section.data.length === 0 ? (
                <div class="
                  rounded-lg border border-dashed border-gray-200 px-4 py-2
                  text-gray-400 italic
                ">
                  No info available
                </div>
              ) : (
                section.data.map((item) => (
                  <a href={item.url} download class="
                    group download-card w-full
                    md:w-80
                  ">
                    <Icon
                      name="lucide:download"
                      class="
                        size-5 text-brand-dark-purple
                        group-hover:text-brand-orange
                      "
                    />
                    <span class="font-body font-medium">{item.description}</span>
                  </a>
                ))
              )}
            </div>
          </>
        ))
      }
    </div>

    <div class="
      shrink-0
      lg:w-1/2
    ">
      <slot name="slideshow" />
    </div>
  </div>
</div>
