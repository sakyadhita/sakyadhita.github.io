---
import Pagination from './ConferencePagination.astro'
import { ordinal_suffix_of, determineLocationLabel } from '../lib'

import type { CollectionEntry } from 'astro:content'

interface Props {
  items: CollectionEntry<'conference'>[]
  color: string
  id?: string
}

const { items, color, id } = Astro.props

const initialIndex = id ? items.findIndex((x) => x.id === id) : 0
const index = initialIndex === -1 ? 0 : initialIndex
const initialPage = Math.floor(index / 9) + 1
---

<div
  id="vertical-stepper-root"
  class="w-fit"
  data-initial-page={initialPage}
  data-initial-index={index}
>
  <div class="stepper-content flex min-h-[666.5px] flex-col items-start px-2">
    {
      items.map((item, idx) => (
        <div
          class:list={[
            'stepper-item group flex w-full flex-col items-start',
            Math.floor(idx / 9) + 1 === initialPage ? 'block' : 'hidden'
          ]}
          data-page={Math.floor(idx / 9) + 1}
          data-item-index={idx}
        >
          <div class="flex w-full items-center">
            <button
              type="button"
              class:list={[
                `
                  stepper-node-btn relative z-10 flex size-9 shrink-0
                  cursor-pointer items-center justify-center rounded-full
                  border-2 transition-all duration-300
                `,
                idx === index
                  ? 'scale-105 bg-brand-dark-purple text-white shadow-lg'
                  : `
                    bg-white text-brand-dark-purple
                    hover:bg-brand-dark-purple hover:text-white
                  `
              ]}
              style={{
                borderColor: color,
                backgroundColor: idx === index ? color : 'white',
                color: idx === index ? 'white' : color
              }}
              data-index={idx}
            >
              <span class="pointer-events-none text-xs font-bold lowercase">
                {ordinal_suffix_of(item.data.confNum)}
              </span>
            </button>

            <button
              type="button"
              class:list={[
                `
                  stepper-label-btn ml-4 max-w-40 cursor-pointer truncate
                  border-none bg-transparent p-0 text-left font-body text-base
                  transition-colors
                  hover:underline
                `,
                idx === index ? 'font-bold opacity-100' : 'opacity-80'
              ]}
              style={{ color: color }}
              data-index={idx}
            >
              {determineLocationLabel(item.data.location)}
            </button>
          </div>

          {/* Connector */}
          {(idx + 1) % 9 !== 0 && idx < items.length - 1 && (
            <div class="my-1 ml-4 min-h-8 w-0.5 opacity-40" style={{ backgroundColor: color }} />
          )}
        </div>
      ))
    }
  </div>

  <div class="stepper-pagination-container">
    <Pagination count={items.length} page={initialPage} size={9} />
  </div>
</div>

<script>
  function initVerticalStepper() {
    const root = document.querySelector('#vertical-stepper-root') as HTMLElement
    if (!root) return

    let currentPage = Number.parseInt(root.dataset.initialPage || '1')
    let currentIndex = Number.parseInt(root.dataset.initialIndex || '0')

    const items = root.querySelectorAll('.stepper-item') as NodeListOf<HTMLElement>
    const nodeBtns = root.querySelectorAll('.stepper-node-btn')
    const labelBtns = root.querySelectorAll('.stepper-label-btn')

    const updateUI = () => {
      // Update visibility based on page
      items.forEach((item, idx) => {
        const page = Number.parseInt(item.dataset.page || '1')
        if (page === currentPage) {
          item.classList.remove('hidden')
          item.classList.add('block')
        } else {
          item.classList.remove('block')
          item.classList.add('hidden')
        }

        // Update active state
        const nodeBtn = nodeBtns[idx] as HTMLButtonElement
        const labelBtn = labelBtns[idx] as HTMLButtonElement
        // const color =
        //   root
        //     .querySelector('.stepper-item')
        //     ?.getAttribute('style')
        //     ?.match(/color:\s*(#[a-f0-9]+)/i)?.[1] || '#6652a0'

        if (idx === currentIndex) {
          nodeBtn.classList.add('scale-105', 'text-white', 'shadow-lg')
          nodeBtn.style.backgroundColor = nodeBtn.style.borderColor
          nodeBtn.style.color = 'white'
          labelBtn.classList.add('font-bold', 'opacity-100')
          labelBtn.classList.remove('opacity-80')
        } else {
          nodeBtn.classList.remove('scale-105', 'text-white', 'shadow-lg')
          nodeBtn.style.backgroundColor = 'white'
          nodeBtn.style.color = nodeBtn.style.borderColor
          labelBtn.classList.remove('font-bold', 'opacity-100')
          labelBtn.classList.add('opacity-80')
        }
      })
    }

    const handleStep = (index: number) => {
      currentIndex = index
      updateUI()
      // Dispatch event for parent (ConferenceDesktop)
      document.dispatchEvent(new CustomEvent('conference-step-change', { detail: { index } }))
    }

    nodeBtns.forEach((btn, idx) => {
      btn.addEventListener('click', () => handleStep(idx))
    })

    labelBtns.forEach((btn, idx) => {
      btn.addEventListener('click', () => handleStep(idx))
    })

    // Pagination listeners
    const paginationContainer = root.querySelector('.stepper-pagination-container')
    if (paginationContainer) {
      paginationContainer.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('button')
        if (
          btn &&
          (btn.classList.contains('page-num-btn') ||
            btn.classList.contains('prev-page-btn') ||
            btn.classList.contains('next-page-btn'))
        ) {
          const newPage = Number.parseInt(btn.dataset.page || '1')
          currentPage = newPage
          // When changing page, auto-select first item of that page as per original React logic
          currentIndex = (currentPage - 1) * 9
          updateUI()
          document.dispatchEvent(
            new CustomEvent('conference-step-change', { detail: { index: currentIndex } })
          )

          // Re-render pagination is hard in static, so we might need a dynamic pagination component
          // Or just hide/show page buttons. For now, let's keep it simple.
        }
      })
    }
  }

  initVerticalStepper()
  document.addEventListener('astro:page-load', initVerticalStepper)
</script>
