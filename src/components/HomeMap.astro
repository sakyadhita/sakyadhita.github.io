---
import { getCollection, render } from 'astro:content'

/**
 * Displays Interactive World Map, containing custom color-coded markers on certain coordinates with custom information
 * upon hover/click.
 */

interface Props {
  disableZooming?: boolean
}

const { disableZooming = false } = Astro.props

const branchesRaw = await getCollection('branch')
const branches = await Promise.all(
  branchesRaw.map(async (b) => {
    const { Content } = await render(b)
    return { ...b, Content }
  })
)

const markers = branches.map((m) => ({
  id: m.id,
  name: m.data.name,
  latitude: m.data.latitude,
  longitude: m.data.longitude,
  isBranch: m.data.isBranch,
  siteLink: m.data.siteLink,
  email: m.data.email
}))
---

<div
  id="home-map-container"
  class="relative size-full overflow-hidden rounded-lg bg-slate-50"
  data-markers={JSON.stringify(markers)}
  data-disable-zooming={disableZooming}
>
  <div
    id="map-tooltip"
    class="
      pointer-events-none absolute z-50 hidden max-w-xs translate-x-4 rounded-md
      border border-brand-grey/20 bg-white p-3 text-black shadow-lg animate-in
      fade-in
    "
  >
  </div>

  {
    branches.map((b) => (
      <template id={`marker-html-${b.id}`}>
        <b.Content />
      </template>
    ))
  }
</div>

<script>
  import * as d3 from 'd3'
  import * as topojson from 'topojson-client'

  interface Marker {
    id: string
    name: string
    latitude: number
    longitude: number
    isBranch: boolean
    siteLink?: string
    email?: string
  }

  function initMap() {
    const container = document.querySelector('#home-map-container') as HTMLElement
    if (!container) return

    const markers: Marker[] = JSON.parse(container.dataset.markers || '[]')
    const disableZooming = container.dataset.disableZooming === 'true'
    const tooltip = document.querySelector('#map-tooltip') as HTMLElement

    // Constants
    const width = 800
    const height = 600
    const geoUrl = 'https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json'

    // Clear existing SVG if any (for HMR)
    container.querySelectorAll('svg').forEach((s) => s.remove())

    const svg = d3
      .select(container)
      .append('svg')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('class', 'size-full')
      .attr('preserveAspectRatio', 'xMidYMid meet')

    const g = svg.append('g')

    // Projection matching react-simple-maps default (Equal Earth)
    const projection = d3
      .geoEqualEarth()
      .scale(160)
      .translate([width / 2, height / 2 + 30])
      .center([-5, 0])

    const path = d3.geoPath().projection(projection)

    // Graticule
    const graticule = d3.geoGraticule()
    g.append('path')
      .datum(graticule)
      .attr('class', 'graticule')
      .attr('d', (d) => path(d as d3.GeoPermissibleObjects))
      .attr('fill', 'none')
      .attr('stroke', '#EAEAEC')
      .attr('stroke-width', 0.5)

    // Fetch and render geographies
    fetch(geoUrl)
      .then((res) => res.json())
      .then((topology) => {
        const countries = topojson.feature(
          topology,
          topology.objects.countries
        ) as unknown as GeoJSON.FeatureCollection

        g.append('g')
          .attr('class', 'countries')
          .selectAll('path')
          .data(countries.features)
          .enter()
          .append('path')
          .attr('d', (d) => path(d as d3.GeoPermissibleObjects))
          .attr('fill', '#BBDBF0')
          .attr('stroke', '#FFFFFF')
          .attr('stroke-width', 0.5)
          .style('outline', 'none')

        // Render Markers
        const markerGroup = g.append('g').attr('class', 'markers')

        markers.forEach((marker) => {
          const coords = projection([marker.longitude, marker.latitude])
          if (!coords) return

          const mColor = marker.isBranch ? '#d77a3d' : '#6652a0'

          const m = markerGroup
            .append('g')
            .attr('class', 'marker cursor-pointer focus:outline-none')
            .attr('transform', `translate(${coords[0] - 12}, ${coords[1] - 24})`)
            .on('mouseenter', (event: MouseEvent) => {
              showTooltip(event, marker)
            })
            .on('mousemove', (event: MouseEvent) => {
              moveTooltip(event)
            })
            .on('mouseleave', () => {
              hideTooltip()
            })
            .on('focus', (event: FocusEvent) => {
              showTooltip(event, marker)
            })
            .on('blur', () => {
              hideTooltip()
            })

          // Pin shape
          m.append('path')
            .attr('d', 'M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z')
            .attr('fill', 'none')
            .attr('stroke', mColor)
            .attr('stroke-width', 2)
            .attr('stroke-linecap', 'round')
            .attr('stroke-linejoin', 'round')

          // Inner circle
          m.append('circle').attr('cx', 12).attr('cy', 10).attr('r', 4).attr('fill', mColor)
        })
      })

    // Zoom and Pan
    const zoom = d3
      .zoom<SVGSVGElement, unknown>()
      .scaleExtent([1, 8])
      .translateExtent([
        [-100, -100],
        [width + 100, height + 100]
      ])
      .on('zoom', (event) => {
        g.attr('transform', event.transform)
        // Maintain stroke widths
        g.selectAll('.countries path').attr('stroke-width', 0.5 / event.transform.k)
        g.selectAll('.graticule').attr('stroke-width', 0.5 / event.transform.k)
      })

    if (!disableZooming) {
      svg.call(zoom)
    }

    // Tooltip functions
    function showTooltip(event: MouseEvent | FocusEvent, marker: Marker) {
      if (!tooltip) return
      tooltip.classList.remove('hidden')

      const template = document.querySelector(`#marker-html-${marker.id}`) as HTMLTemplateElement
      const htmlContent = template?.innerHTML || ''

      tooltip.innerHTML = `
        <div class="flex flex-col gap-1">
          ${
            marker.siteLink
              ? `<a href="${marker.siteLink}" target="_blank" rel="noreferrer" class="font-bold text-brand-orange hover:underline decoration-brand-orange">${marker.name}</a>`
              : `<span class="font-bold text-brand-dark-purple">${marker.name}</span>`
          }
          ${marker.email ? `<div class="text-sm text-brand-dark-grey">${marker.email}</div>` : ''}
          ${
            htmlContent
              ? `<div class="prose prose-sm mt-2 max-w-none leading-tight italic text-brand-dark-grey">${htmlContent}</div>`
              : ''
          }
        </div>
      `
      moveTooltip(event)
    }

    function moveTooltip(event: MouseEvent | FocusEvent) {
      if (!tooltip || !container) return
      const containerRect = container.getBoundingClientRect()
      const clientX = 'clientX' in event ? event.clientX : 0
      const clientY = 'clientY' in event ? event.clientY : 0

      const x = clientX - containerRect.left
      const y = clientY - containerRect.top

      tooltip.style.left = `${x}px`
      tooltip.style.top = `${y}px`

      // Flip tooltip if it goes out of bounds
      const tooltipRect = tooltip.getBoundingClientRect()
      if (x + tooltipRect.width > containerRect.width) {
        tooltip.style.left = `${x - tooltipRect.width - 20}px`
      }
    }

    function hideTooltip() {
      if (!tooltip) return
      tooltip.classList.add('hidden')
    }
  }

  // Initialize
  initMap()
  document.addEventListener('astro:page-load', initMap)
</script>

<style>
  #map-tooltip {
    transition:
      opacity 0.2s,
      transform 0.2s;
  }
</style>
