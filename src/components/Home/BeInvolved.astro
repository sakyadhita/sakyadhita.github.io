---
/**
 * Renders one tile for the Be Involved Section of the Home page.
 *
 * @summary Displays one tile for Home Page's Be Involved sub-section.
 * @author Amrit Kaur Singh
 */
import { getImage } from 'astro:assets'

import { getRawImage } from '../../lib/images'
import CustomButton from '../CustomButton.astro'

interface Props {
  description: string
  image_url: string
  button_title: string
  redirect_link: string
  openInSameTab?: boolean | string
}

const { description, image_url, button_title, redirect_link, openInSameTab } = Astro.props

const rawImage = getRawImage(image_url)
const optimizedImage = rawImage
  ? await getImage({ src: rawImage, format: 'webp', width: 800 })
  : null
---

<div
  id={button_title}
  class="
    group h-[450px] w-full flex-1 bg-[no-repeat,no-repeat]
    bg-size-[cover,contain] bg-position-[center,top] font-body text-2xl
    text-white shadow-[0px_0px_4px_2px_rgba(0,0,0,0.25)] transition-transform
    hover:scale-105
  "
  style={{ backgroundImage: `url(${optimizedImage?.src || image_url})` }}
>
  <div
    class="
      flex size-full flex-col items-center justify-end bg-black/40 p-[10vw_20vw]
      transition-colors
      group-hover:bg-transparent
      md:p-[4vw_6vw]
      lg:p-[4vw_7vw]
    "
  >
    <p class="mb-6 text-center">{description}</p>
    <CustomButton
      openInSameTab={openInSameTab === 'true' || openInSameTab === true}
      redirect_link={redirect_link}
      text={button_title}
    />
  </div>
</div>
