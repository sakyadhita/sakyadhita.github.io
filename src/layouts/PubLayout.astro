---
import { getImage } from 'astro:assets'
import { getCollection } from 'astro:content'

import PageLayout from './PageLayout.astro'
import EPublications from '../components/Layouts/EPublications'
import ResourcesNavBar from '../components/Main/ResourcesNavBar.astro'
import { getRawImage } from '../lib/images'

const epublicationsRaw = await getCollection('publication')
const epublications = await Promise.all(
  epublicationsRaw.map(async (p) => {
    const raw = getRawImage(p.data.imageLink)
    if (raw) {
      const optimized = await getImage({ src: raw, format: 'webp', width: 400 })
      return { ...p, data: { ...p.data, optimizedImage: optimized.src } }
    }
    return p
  })
)
const categories = [...new Set(epublications.map((p) => p.data.category))]
const sections = categories.map((c) => ({
  section_title: c,
  section_list: epublications.filter((p) => p.data.category === c)
}))
const featuredEpubs = epublications.filter((p) => p.data.feature)
---

<PageLayout>
  <ResourcesNavBar>
    <EPublications client:idle sections={sections} featuredEpubs={featuredEpubs}>
      <slot />
    </EPublications>
  </ResourcesNavBar>
</PageLayout>
