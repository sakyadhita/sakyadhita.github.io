---
import { getCollection } from 'astro:content'

import PageLayout from './PageLayout.astro'
import Newsletters from '../components/Layouts/Newsletters.astro'
import ResourcesNavBar from '../components/Main/ResourcesNavBar.astro'
import ResourcesHeader from '../components/ResourcesHeader.astro'
import { getOptimizedImage } from '../lib/images'

const newsletters = await getCollection('newsletter')

const { frontmatter } = Astro.props
const optimizedHeader = await getOptimizedImage(frontmatter.image, 1600)

// return a reverse sort of the newsletter
const reverseSortNewsletter = newsletters.toSorted((a, b) => {
  let a_d = a.data
  let b_d = b.data

  if (a_d.year < b_d.year) return 1
  if (a_d.year > b_d.year) return -1

  if (a_d.volume < b_d.volume) return 1
  if (a_d.volume > b_d.volume) return -1

  if (a_d.number < b_d.number) return 1
  if (a_d.number > b_d.number) return -1

  return 0
})
---

<PageLayout>
  <ResourcesNavBar>
    <ResourcesHeader
      title={frontmatter.title}
      text={frontmatter.description}
      image={optimizedHeader?.src || frontmatter.image}
    />
    <Newsletters newsletters={reverseSortNewsletter}>
      <slot />
    </Newsletters>
  </ResourcesNavBar>
</PageLayout>
