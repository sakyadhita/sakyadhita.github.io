---
import { getCollection } from 'astro:content'
import { getImage } from 'astro:assets'
import { getRawImage } from '../lib/images'

import PageLayout from './PageLayout.astro'
import ResourcesNavBar from '../components/Main/ResourcesNavBar'
import Newsletters from '../components/Layouts/Newsletters'

const newslettersRaw = await getCollection('newsletter')
const newsletters = await Promise.all(
  newslettersRaw.map(async (n) => {
    const raw = getRawImage(n.data.imageLink)
    if (raw) {
      const optimized = await getImage({ src: raw, format: 'webp', width: 300 })
      return { ...n, data: { ...n.data, optimizedImage: optimized.src } }
    }
    return n
  })
)

const { frontmatter } = Astro.props
// return a reverse sort of the newsletter
let reverseSortNewsletter = newsletters.sort((a, b) => {
  let a_d = a.data
  let b_d = b.data

  if (a_d.year < b_d.year) return 1
  if (a_d.year > b_d.year) return -1

  if (a_d.volume < b_d.volume) return 1
  if (a_d.volume > b_d.volume) return -1

  if (a_d.number < b_d.number) return 1
  if (a_d.number > b_d.number) return -1

  return 0
})
---

<PageLayout>
  <ResourcesNavBar client:idle>
    <Newsletters client:idle frontmatter={frontmatter} newsletters={reverseSortNewsletter}>
      <slot />
    </Newsletters>
  </ResourcesNavBar>
</PageLayout>
