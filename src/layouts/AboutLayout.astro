---
import { getCollection, render } from 'astro:content'
import { getImage } from 'astro:assets'
import { getRawImage } from '../lib/images'
import { marked } from 'marked'

import PageLayout from './PageLayout.astro'
import ResourcesHeader from '../components/ResourcesHeader.astro'
import AboutUs from '../components/Layouts/AboutUs'

const committeesRaw = await getCollection('exco')
const committees = await Promise.all(
  committeesRaw.map(async (c) => {
    const raw = getRawImage(c.data.imageLink)
    const htmlBody = await marked.parse(c.body || '')
    let optimizedImage = null
    if (raw) {
      const optimized = await getImage({ src: raw, format: 'webp', width: 400 })
      optimizedImage = optimized.src
    }
    return { ...c, data: { ...c.data, optimizedImage, htmlBody } }
  })
)
const sections = await getCollection('section', ({ data }) => {
  return data.isPublished == true && data.page == 'AboutUs'
})
const contents = await Promise.all(
  sections.map(async (s) => {
    const { Content } = await render(s)
    return Content
  })
)

const { frontmatter } = Astro.props
const rawHeader = getRawImage(frontmatter.image)
const optimizedHeader = rawHeader
  ? await getImage({ src: rawHeader, format: 'webp', width: 1600 })
  : null

function makeIdURLFriendly(idString: string) {
  return idString
    .replace(/\s+/g, '-')
    .replace(/:/g, '')
    .replace(/[^a-z0-9-]/gi, '')
    .toLowerCase()
}
---

<PageLayout>
  <ResourcesHeader
    title={frontmatter.title}
    text={frontmatter.description}
    image={optimizedHeader?.src || frontmatter.image}
  />
  <AboutUs client:load committees={committees} sections={sections}>
    {
      sections.map((section, i) => {
        const Content = contents[i]

        return (
          <div class="section">
            <div class="scroll" id={makeIdURLFriendly(section.data.title)} />
            <h1>{section.data.title}</h1>
            <Content />
          </div>
        )
      })
    }
    <slot />
  </AboutUs>
</PageLayout>
