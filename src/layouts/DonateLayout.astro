---
import PageLayout from './PageLayout.astro'
import CustomButton from '../components/CustomButton.astro'
import ResourcesHeader from '../components/ResourcesHeader.astro'
import BeInvolved from '../components/Home/BeInvolved.astro'
import { SITE_PAGES } from '../constants/links'
import { getOptimizedImage } from '../lib/images'

const { frontmatter } = Astro.props
const optimizedWorkingTogether = await getOptimizedImage(
  '/assets/Donate Page/WorkingTogether-440px.jpeg',
  440
)
const optimizedAmazonSmile = await getOptimizedImage('/assets/Donate Page/AmazonSmile-01.jpeg', 350)
---

<PageLayout>
  <div id="donate-page" class="font-body">
    {/* Responsive Headers using Tailwind utilities instead of React state */}
    <ResourcesHeader
      title={frontmatter.title}
      text={frontmatter.description}
      image={frontmatter.image}
    />

    {/* All page content */}
    <div class="flex flex-col px-4 md:px-12 py-12 md:py-24">
      <div class="flex flex-col lg:flex-row justify-center items-start gap-8 lg:gap-0">
        {/* PayPal Info */}
        <section class="flex-1 flex flex-col items-center mx-0 lg:mx-8 text-center lg:text-left">
          <h1 class="font-heading font-bold text-3xl md:text-5xl mb-4">PayPal</h1>
          <hr class="w-1/2 h-1.5 bg-brand-orange border-none mb-8" />
          <p class="max-w-2xl text-gray-700 leading-relaxed">
            Your donation makes a difference. In the tradition of the Buddha our work is offered
            publicly, and free of charge when possible. Consequently, the vital work Sakyadhita
            performs is funded entirely through donations, memberships, and conference fees. Your
            generosity allows us to keep conference fees low, while offering conference scholarships
            to female monastics who otherwise would not be able to attend our bi-annual conferences.
          </p>
          <p class="mt-6 font-bold">Make a One-Time or Reoccuring Donation</p>
          {/* PayPal Donate Button */}
          <div class="mt-8 flex justify-center h-12">
            <form action="https://www.paypal.com/donate" method="post" target="_blank">
              <input type="hidden" name="hosted_button_id" value="78ZSMXL4ZSYJQ" />
              <input
                type="image"
                src="https://www.paypalobjects.com/en_US/i/btn/btn_donateCC_LG.gif"
                name="submit"
                title="PayPal - The safer, easier way to pay online!"
                alt="Donate with PayPal button"
                class="hover:opacity-90 transition-opacity"
              />
              <img alt="" src="https://www.paypal.com/en_US/i/scr/pixel.gif" width="1" height="1" />
            </form>
          </div>
          <img
            class="mt-8 w-full max-w-sm h-auto rounded-lg shadow-md"
            alt="13th Conference"
            src={optimizedWorkingTogether?.src || '/assets/Donate Page/WorkingTogether-440px.jpeg'}
          />
        </section>
        {/* AmazonSmile Info */}
        <section
          class="flex-1 flex flex-col items-center mx-0 lg:mx-8 text-center lg:text-left mt-12 lg:mt-0"
        >
          <h1 class="font-heading font-bold text-3xl md:text-5xl mb-4">AmazonSmile</h1>
          <hr class="w-1/2 h-1.5 bg-brand-orange border-none mb-8" />
          <p class="max-w-2xl text-gray-700 leading-relaxed">
            You can also support Sakyadhita International by shopping online through AmazonSmile, a
            simple and automatic way for you to support Sakyadhita every time you shop, at no cost
            to you. When you shop at AmazonSmile, you’ll find the exact same low prices, vast
            selection and convenient shopping experience as Amazon.com, with the added bonus that
            Amazon will donate a portion of the purchase price to Sakyadhita.
          </p>
          <img
            class="mt-8 w-full max-w-sm h-auto rounded-lg shadow-md"
            alt="AmazonSmile Promo"
            src={optimizedAmazonSmile?.src || '/assets/Donate Page/AmazonSmile-01.jpeg'}
          />
          <div class="mt-8">
            <CustomButton text="Support" redirect_link="http://smile.amazon.com/ch/95-4112765" />
          </div>
        </section>
      </div>

      <div class="hidden md:flex justify-center">
        <hr class="w-1/2 h-2.5 bg-brand-orange border-none my-24" />
      </div>

      {/* Support Us Section */}
      <section class="mt-12 md:mt-0 flex flex-col items-center md:items-start">
        <h1 class="font-heading font-bold text-3xl md:text-5xl mb-8">Support Us via Involvement</h1>
        <p class="mb-8 text-gray-700">Get involved and support us!</p>
        <div class="w-full flex flex-col md:flex-row gap-8 lg:gap-12 justify-evenly items-center">
          <BeInvolved
            description="Become a member of Sakyadhita!"
            image_url="/assets/Join Us Page/JoinUs.jpg"
            openInSameTab="true"
            redirect_link={SITE_PAGES.JOIN_US}
            button_title="Join Us"
          />
          <BeInvolved
            description="Interested in helping us with anything from writing content to building?"
            image_url="/assets/Join Us Page/Volunteer.jpg"
            openInSameTab="true"
            redirect_link={SITE_PAGES.VOLUNTEER}
            button_title="Volunteer"
          />
          <BeInvolved
            description="Help us grow and continue to connect by donating in any amount"
            image_url="/assets/Donate Page/Donate.jpg"
            openInSameTab="true"
            redirect_link={SITE_PAGES.DONATE}
            button_title="Donate"
          />
        </div>
      </section>
    </div>
  </div>
</PageLayout>
