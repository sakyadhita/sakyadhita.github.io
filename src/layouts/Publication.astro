---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'

import PageLayout from './PageLayout.astro'
import EPubCard from '../components/EPubs/EPubCard.astro'
import EPubSection from '../components/EPubs/EPubSection.astro'
import ResourcesNavBar from '../components/Main/ResourcesNavBar.astro'
import Slideshow from '../components/Slideshow.astro'
import { getAssetUrl } from '../lib/images'

const publicationsRaw = await getCollection('publication')
const publications = publicationsRaw.toSorted((a, b) => a.data.id - b.data.id)

const categories = [...new Set(publications.map((p) => p.data.category))]
const sections = categories.map((c) => ({
  section_title: c,
  section_list: publications.filter((p) => p.data.category === c)
}))
const featuredEpubs = publications.filter((p) => p.data.feature)

const { frontmatter } = Astro.props
---

<PageLayout>
  <ResourcesNavBar>
    <div id="EPubPage">
      {/* Landing Page Content */}
      <div id="landing-view">
        <Slideshow
          height="450px"
          width="100%"
          className="
            max-md:h-[530px]
            lg:h-[450px]
          "
        >
          {
            featuredEpubs.map((epub) => (
              <div
                class="
                  embla__slide relative flex size-full items-center
                  justify-center bg-brand-dark-purple text-white
                  lg:items-stretch lg:justify-start
                "
              >
                <div
                  class="
                    absolute top-0 left-0 z-10 block h-fit bg-brand-dark-purple
                    p-2.5 text-left font-heading
                    max-md:bg-brand-dark-purple/90 max-md:p-5
                    max-sm:mx-auto max-sm:mt-10 max-sm:h-108 max-sm:w-52
                    md:w-72
                    lg:m-8 lg:mt-8 lg:ml-40 lg:w-80
                  "
                >
                  <h1
                    class="
                      text-4xl/tight font-bold
                      max-sm:text-lg/relaxed
                    "
                  >
                    {epub.data.title}
                  </h1>
                  <h2
                    class="
                      text-lg/relaxed font-bold
                      max-md:hidden
                    "
                  >
                    {epub.data.author}
                  </h2>
                  <p
                    class="
                      font-body text-base/relaxed font-normal
                      max-sm:leading-normal
                    "
                  >
                    {epub.data.description}
                  </p>
                  <button
                    type="button"
                    class="
                      read-more-btn mt-4 h-14 w-48 cursor-pointer rounded-full
                      border-none bg-brand-orange text-center font-body
                      text-xl/relaxed text-white
                      max-sm:h-9 max-sm:w-36 max-sm:text-sm
                    "
                    data-url={getAssetUrl(epub.data.pdfLink)}
                  >
                    Read More
                  </button>
                </div>
                <Image
                  class="
                    absolute top-0 right-0 m-0 size-full max-w-3xl
                    bg-brand-dark-purple object-cover p-0
                  "
                  src={epub.data.imageLink}
                  alt=""
                  width={1200}
                  height={450}
                />
              </div>
            ))
          }
        </Slideshow>

        <div class="mx-auto max-w-5xl px-4">
          <slot />
        </div>

        <div class="
          sections-container mt-14 mb-24
          max-md:m-0
        ">
          {sections.map((section) => <EPubSection publication_section={section} />)}
        </div>
      </div>

      {/* Individual Section Views (rendered for all but hidden) */}
      <div id="details-view" class="hidden">
        {
          sections.map((section) => (
            <div
              id={`section-${section.section_title.replaceAll(/\s+/g, '-')}`}
              class="section-details hidden"
            >
              <div
                class="
                  relative mx-[10vw] mt-12 mb-24
                  lg:mt-32
                "
              >
                {/* Header */}
                <div
                  class="
                    relative top-0 left-0 flex h-24 w-full flex-col
                    lg:h-12 lg:flex-row
                  "
                >
                  <div
                    class="
                      absolute -top-12 left-[-10vw] block h-24
                      w-[calc(100%+20vw)]
                      shadow-[0px_2px_2px_0px_rgba(0,0,0,0.25)]
                      lg:hidden
                    "
                  />
                  <h1
                    class="
                      z-10 w-full text-center font-heading text-2xl/tight
                      font-bold
                      lg:text-4xl/relaxed lg:font-normal
                    "
                  >
                    {section.section_title}
                  </h1>
                  <button
                    type="button"
                    class="
                      back-btn z-10 mx-auto mt-3 mb-5 block w-fit cursor-pointer
                      border-none bg-inherit p-0 text-center font-body
                      text-base/tight
                      hover:underline
                      lg:absolute lg:bottom-0 lg:left-6 lg:mb-4
                      lg:text-lg/relaxed
                    "
                  >
                    &lt; <span class="lg:hidden">Back to latest</span>
                    <span
                      class="
                        hidden
                        lg:inline
                      "
                    >
                      Back
                    </span>
                  </button>
                  <p
                    class="
                      absolute right-6 bottom-0 z-10 hidden w-fit font-body
                      text-lg/relaxed no-underline
                      lg:block
                    "
                  >
                    All <span class="text-brand-orange">({section.section_list.length})</span>
                  </p>
                </div>

                {/* Content */}
                <div
                  class="
                    relative mx-[-25px] flex flex-wrap items-start
                    justify-center text-center
                  "
                >
                  {section.section_list.map((pub) => (
                    <div class="flex flex-col items-center justify-start">
                      <EPubCard
                        title={pub.data.title}
                        author={pub.data.author}
                        image={pub.data.imageLink}
                        pdfLink={pub.data.pdfLink}
                      />
                      <button
                        type="button"
                        class="
                          read-btn mb-5 h-9 w-40 cursor-pointer rounded-full
                          border-none bg-brand-orange text-white
                          lg:hidden
                        "
                        data-url={getAssetUrl(pub.data.pdfLink)}
                      >
                        Read
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </ResourcesNavBar>
</PageLayout>

<script>
  function initEPubPage() {
    const landingView = document.querySelector('#landing-view')
    const detailsView = document.querySelector('#details-view')
    const backButtons = document.querySelectorAll('.back-btn')
    const readMoreButtons = document.querySelectorAll('.read-more-btn')
    const readButtons = document.querySelectorAll('.read-btn')

    const showSection = (title: string) => {
      const sectionId = `section-${title.replaceAll(/\s+/g, '-')}`
      const targetSection = document.querySelector(`#${sectionId}`)

      if (landingView && detailsView && targetSection) {
        landingView.classList.add('hidden')
        detailsView.classList.remove('hidden')

        // Hide all sections first
        document.querySelectorAll('.section-details').forEach((s) => s.classList.add('hidden'))
        // Show target
        targetSection.classList.remove('hidden')

        window.scrollTo({ top: 0, behavior: 'smooth' })
      }
    }

    const showLanding = () => {
      if (landingView && detailsView) {
        landingView.classList.remove('hidden')
        detailsView.classList.add('hidden')
        window.scrollTo({ top: 0, behavior: 'smooth' })
      }
    }

    // Use event delegation for section toggles as they might be inside EPubSection
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement
      const btn = target.closest('.section-toggle') as HTMLElement
      if (btn) {
        const section = btn.dataset.section
        if (section) showSection(section)
      }
    })

    backButtons.forEach((btn) => {
      btn.addEventListener('click', showLanding)
    })

    readMoreButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const url = (btn as HTMLElement).dataset.url
        if (url) globalThis.location.href = url
      })
    })

    readButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const url = (btn as HTMLElement).dataset.url
        if (url) window.open(url, '_blank', 'noreferrer')
      })
    })
  }

  initEPubPage()
  document.addEventListener('astro:page-load', initEPubPage)
</script>
