---
import { getImage } from 'astro:assets'
import { getCollection, render } from 'astro:content'

import PageLayout from './PageLayout.astro'
import ResourcesNavBar from '../components/Main/ResourcesNavBar.astro'
import ResourcesHeader from '../components/ResourcesHeader.astro'
import { getRawImage } from '../lib/images'

const sectionsRaw = await getCollection('section', ({ data }) => {
  return data.isPublished == true && data.page == 'BuddhistCulture'
})
const sections = await Promise.all(
  sectionsRaw.map(async (s) => {
    const { Content } = await render(s)
    return { ...s, Content }
  })
)

const { frontmatter } = Astro.props
const rawHeader = getRawImage(frontmatter.image)
const optimizedHeader = rawHeader
  ? await getImage({ src: rawHeader, format: 'webp', width: 1600 })
  : null
---

<PageLayout>
  <ResourcesNavBar>
    <div class="relative w-full">
      <ResourcesHeader
        image={optimizedHeader?.src || frontmatter.image}
        title={frontmatter.title}
        text={frontmatter.description}
      />

      <div class="mx-auto w-full max-w-4xl px-6 py-12 font-body
        md:px-12 md:py-24">
        {
          sections.length === 0 ? (
            <div class="flex h-64 items-center justify-center">
              <h1 class="text-center font-heading text-3xl font-bold">Coming soon</h1>
            </div>
          ) : (
            <div
              class="
                prose prose-lg max-w-none text-black
                prose-headings:mb-8 prose-headings:font-heading
                prose-headings:font-bold
                prose-img:mx-auto prose-img:mt-12 prose-img:w-full
                prose-img:rounded-lg prose-img:shadow-lg
              "
            >
              {sections.map((item, index) => (
                <div class="mb-12">
                  <div id={item.data.title.replaceAll(' ', '')} />
                  <h1>{item.data.title}</h1>
                  <item.Content />
                  {index === sections.length - 1 ? null : <hr class="my-12 border-brand-orange" />}
                </div>
              ))}
              <slot />
            </div>
          )
        }
      </div>
    </div>
  </ResourcesNavBar>
</PageLayout>
