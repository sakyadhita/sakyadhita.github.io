---
import { Image } from 'astro:assets'

import PageLayout from './PageLayout.astro'
import amazonSmileImg from '../assets/Donate Page/AmazonSmile-01.jpeg'
import workingTogetherImg from '../assets/Donate Page/WorkingTogether-440px.jpeg'
import CustomButton from '../components/CustomButton.astro'
import BeInvolved from '../components/Home/BeInvolved.astro'
import ResourcesHeader from '../components/ResourcesHeader.astro'
import { CONTACT_INFO, SITE_PAGES, PAYPAL_CONFIG } from '../SiteMetadata'

const { frontmatter } = Astro.props
---

<PageLayout>
  <div id="donate-page" class="font-body">
    {/* Responsive Headers using Tailwind utilities instead of React state */}
    <ResourcesHeader
      title={frontmatter.title}
      text={frontmatter.description}
      image={frontmatter.image}
    />

    {/* All page content */}
    <div class="
      flex flex-col px-4 py-12
      md:px-12 md:py-24
    ">
      <div class="
        flex flex-col items-start justify-center gap-8
        lg:flex-row lg:gap-0
      ">
        {/* PayPal Info */}
        <section
          class="
            mx-0 flex flex-1 flex-col items-center text-center
            lg:mx-8 lg:text-left
          "
        >
          <h1 class="
            mb-4 font-heading text-3xl font-bold
            md:text-5xl
          ">PayPal</h1>
          <hr class="mb-8 h-1.5 w-1/2 border-none bg-brand-orange" />
          <p class="max-w-2xl leading-relaxed text-gray-700">
            Your donation makes a difference. In the tradition of the Buddha our work is offered
            publicly, and free of charge when possible. Consequently, the vital work Sakyadhita
            performs is funded entirely through donations, memberships, and conference fees. Your
            generosity allows us to keep conference fees low, while offering conference scholarships
            to female monastics who otherwise would not be able to attend our bi-annual conferences.
          </p>
          <p class="mt-6 font-bold">Make a One-Time or Reoccuring Donation</p>
          {/* PayPal Donate Button */}
          <div class="mt-8 flex h-12 justify-center">
            <form action={PAYPAL_CONFIG.DONATE_URL} method="post" target="_blank">
              <input type="hidden" name="hosted_button_id" value={PAYPAL_CONFIG.HOSTED_BUTTON_ID} />
              <input
                type="image"
                src={PAYPAL_CONFIG.DONATE_BUTTON_IMG}
                name="submit"
                title="PayPal - The safer, easier way to pay online!"
                alt="Donate with PayPal button"
                class="
                  transition-opacity
                  hover:opacity-90
                "
              />
              <img alt="" src={PAYPAL_CONFIG.PIXEL_IMG} width="1" height="1" />
            </form>
          </div>
          <Image
            class="mt-8 h-auto w-full max-w-sm rounded-lg shadow-md"
            alt="13th Conference"
            src={workingTogetherImg}
            width={440}
          />
        </section>
        {/* AmazonSmile Info */}
        <section
          class="
            mx-0 mt-12 flex flex-1 flex-col items-center text-center
            lg:mx-8 lg:mt-0 lg:text-left
          "
        >
          <h1 class="
            mb-4 font-heading text-3xl font-bold
            md:text-5xl
          ">AmazonSmile</h1>
          <hr class="mb-8 h-1.5 w-1/2 border-none bg-brand-orange" />
          <p class="max-w-2xl leading-relaxed text-gray-700">
            You can also support Sakyadhita International by shopping online through AmazonSmile, a
            simple and automatic way for you to support Sakyadhita every time you shop, at no cost
            to you. When you shop at AmazonSmile, you’ll find the exact same low prices, vast
            selection and convenient shopping experience as Amazon.com, with the added bonus that
            Amazon will donate a portion of the purchase price to Sakyadhita.
          </p>
          <Image
            class="mt-8 h-auto w-full max-w-sm rounded-lg shadow-md"
            alt="AmazonSmile Promo"
            src={amazonSmileImg}
            width={350}
          />
          <div class="mt-8">
            <CustomButton text="Support" redirect_link={CONTACT_INFO.AMAZON_SMILE_URL} />
          </div>
        </section>
      </div>

      <div class="
        hidden justify-center
        md:flex
      ">
        <hr class="my-24 h-2.5 w-1/2 border-none bg-brand-orange" />
      </div>

      {/* Support Us Section */}
      <section class="
        mt-12 flex flex-col items-center
        md:mt-0 md:items-start
      ">
        <h1 class="
          mb-8 font-heading text-3xl font-bold
          md:text-5xl
        ">
          Support Us via Involvement
        </h1>
        <p class="mb-8 text-gray-700">Get involved and support us!</p>
        <div
          class="
            flex w-full flex-col items-center justify-evenly gap-8
            md:flex-row
            lg:gap-12
          "
        >
          <BeInvolved
            description="Become a member of Sakyadhita!"
            image_url="/assets/Join Us Page/JoinUs.jpg"
            openInSameTab="true"
            redirect_link={SITE_PAGES.JOIN_US}
            button_title="Join Us"
          />
          <BeInvolved
            description="Interested in helping us with anything from writing content to building?"
            image_url="/assets/Join Us Page/Volunteer.jpg"
            openInSameTab="true"
            redirect_link={SITE_PAGES.VOLUNTEER}
            button_title="Volunteer"
          />
          <BeInvolved
            description="Help us grow and continue to connect by donating in any amount"
            image_url="/assets/Donate Page/Donate.jpg"
            openInSameTab="true"
            redirect_link={SITE_PAGES.DONATE}
            button_title="Donate"
          />
        </div>
      </section>
    </div>
  </div>
</PageLayout>
