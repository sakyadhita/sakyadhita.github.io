---
import LotusHeader from '../assets/Lotus_Header.png'
import ResourcesNavBar from '../components/ResourcesNavBar.astro'
import SectionHeader from '../components/SectionHeader.astro'
import PageLayout from '../layouts/PageLayout.astro'

const frontmatter = {
  title: 'Sakyadhita Resources',
  description: 'All information related and central to Sakyadhita.',
  image: LotusHeader
}
---

<PageLayout hideFooter={true}>
  <ResourcesNavBar>
    <div class="w-full">
      <SectionHeader
        image={frontmatter.image}
        title={frontmatter.title}
        text={frontmatter.description}
        heightClass="h-[calc(100vh-128px)]"
        centered={false}
      />
    </div>
    <slot />
  </ResourcesNavBar>
</PageLayout>
