---
import { getCollection, render } from 'astro:content'

import LotusHeader from '../assets/Lotus_Header.png'
import ResourcesHeader from '../components/ResourcesHeader.astro'
import ResourcesNavBar from '../components/ResourcesNavBar.astro'
import PageLayout from '../layouts/PageLayout.astro'

const sectionsRaw = await getCollection('section', ({ data }) => {
  return data.isPublished == true && data.page == 'OrdinationIssue'
})
const sections = await Promise.all(
  sectionsRaw.map(async (s) => {
    const { Content } = await render(s)
    return { ...s, Content }
  })
)

const frontmatter = {
  title: 'Ordination',
  description: 'Discussing buddhist ordination',
  image: LotusHeader
}
---

<PageLayout>
  <ResourcesNavBar>
    <div class="relative w-full">
      <ResourcesHeader
        image={frontmatter.image}
        title={frontmatter.title}
        text={frontmatter.description}
      />

      <div class="
        mx-auto w-full max-w-4xl px-6 py-12 font-body
        md:px-12 md:py-24
      ">
        {
          sections.length === 0 ? (
            <div class="flex h-64 items-center justify-center">
              <h1 class="text-center font-heading text-3xl font-bold">Coming soon</h1>
            </div>
          ) : (
            <div
              class="
                prose prose-lg max-w-none
                prose-headings:mb-8 prose-headings:font-heading
                prose-headings:font-bold
                prose-img:mx-auto prose-img:mt-12 prose-img:w-full
                prose-img:rounded-lg prose-img:shadow-lg
              "
            >
              {sections.map((section) => (
                <div class="mb-12">
                  <h2 id={section.data.title.replaceAll(' ', '')}>{section.data.title}</h2>
                  <section.Content />
                </div>
              ))}
              <slot />
            </div>
          )
        }
      </div>
    </div>
  </ResourcesNavBar>
</PageLayout>
