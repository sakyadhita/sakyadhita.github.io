---
import { getImage } from 'astro:assets'
import { type CollectionEntry, getCollection } from 'astro:content'
import { marked } from 'marked'

import ConferenceDesktop from '../../components/Conference/ConferenceDesktop'
import MobileConference from '../../components/Conference/MobileConference'
import PageLayout from '../../layouts/PageLayout.astro'
import { getRawImage, getAssetUrl } from '../../lib/images'

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const conferences = await getCollection('conference')
  return conferences.map((conference) => ({
    params: { slug: conference.id },
    props: { conference }
  }))
}
// 2. For your template, you can get the entry directly from the prop

interface Props {
  conference: CollectionEntry<'conference'>
}
const { conference } = Astro.props

const conferencesRaw = await getCollection('conference')
const conferences = await Promise.all(
  conferencesRaw.map(async (c) => {
    const htmlBody = await marked.parse(c.body || '')
    let optimizedImages = null
    if (c.data.slideShowImages) {
      optimizedImages = await Promise.all(
        c.data.slideShowImages.map(async (img) => {
          const raw = getRawImage(img)
          if (raw) {
            const opt = await getImage({ src: raw, format: 'webp', width: 1200 })
            return opt.src
          }
          return img
        })
      )
    }

    const resolveList = (list?: { description: string; url: string }[]) =>
      list ? list.map((i) => ({ ...i, url: getAssetUrl(i.url) })) : undefined

    return {
      ...c,
      data: {
        ...c.data,
        optimizedImages,
        htmlBody,
        brochures: resolveList(c.data.brochures),
        programs: resolveList(c.data.programs),
        abstracts: resolveList(c.data.abstracts),
        presentations: resolveList(c.data.presentations)
      }
    }
  })
)

const data = conferences.toReversed()
---

<PageLayout>
  <div class="
    hidden
    lg:block
  ">
    <ConferenceDesktop client:only="react" data={data} id={conference.id} />
  </div>
  <div class="
    block
    lg:hidden
  ">
    <MobileConference client:only="react" data={data} id={conference.id} />
  </div>
</PageLayout>
