---
import { type CollectionEntry, getCollection } from 'astro:content'

import ConferenceSection from '../../components/ConferenceSection.astro'
import PageLayout from '../../layouts/PageLayout.astro'

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const conferences = await getCollection('conference')
  return conferences.map((conference) => ({
    params: { slug: conference.id },
    props: { conference }
  }))
}
// 2. For your template, you can get the entry directly from the prop

interface Props {
  conference: CollectionEntry<'conference'>
}
const { conference } = Astro.props

const conferencesRaw = await getCollection('conference')
const data = conferencesRaw.toReversed()
---

<PageLayout>
  <ConferenceSection data={data} id={conference.id} />
</PageLayout>
