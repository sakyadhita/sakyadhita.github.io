---
import { Image } from 'astro:assets'

import PageLayout from '../layouts/PageLayout.astro'
import amazonSmileImg from '../assets/Donate Page/AmazonSmile-01.jpeg'
import workingTogetherImg from '../assets/Donate Page/WorkingTogether-440px.jpeg'
import BeInvolved from '../components/Home/BeInvolved.astro'
import PayPal from '../components/PayPal'
import { PAYPAL_CONFIG, SITE_PAGES } from '../SiteMetadata'
import LotusHeader from '../assets/Lotus_Header.png'
import JoiningHandsImg from '../assets/Join Us Page/JoinUs.jpg'
import DonateImg from '../assets/Donate Page/Donate.jpg'

const frontmatter = {
  title: 'Donate & Support',
  description: 'Donate to Sakyadhita',
  image: LotusHeader
}
---

<PageLayout>
  <div
    class="
      mx-auto w-full max-w-7xl px-6 py-12
      md:px-12 md:py-24
    "
  >
    <div class="space-y-16">
      {/* Header section */}
      <section class="prose max-w-none text-center">
        <h1
          class="
            mb-6 font-heading text-4xl font-bold text-black
            md:text-5xl
          "
        >
          {frontmatter.title}
        </h1>
        <p class="mx-auto max-w-3xl font-body text-xl text-gray-700 italic">
          {frontmatter.description}
        </p>
      </section>

      {/* Main content grid */}
      <div
        class="
          grid grid-cols-1 gap-12
          lg:grid-cols-2
        "
      >
        {/* Left Column: Direct Donation */}
        <section
          class="
            space-y-8 rounded-3xl bg-[#f7f7f7] p-8
            md:p-12
          "
        >
          <div
            class="
              prose prose-lg max-w-none font-body text-gray-700
              prose-headings:font-heading prose-headings:font-bold
              prose-headings:text-black
            "
          >
            <slot />
          </div>

          <div class="pt-8">
            <h3 class="mb-6 font-heading text-2xl font-bold text-black">Make a Contribution</h3>
            <PayPal client:only="react" />
          </div>
        </section>

        {/* Right Column: Other ways to help */}
        <section class="space-y-12">
          <div
            class="
              group overflow-hidden rounded-3xl bg-white shadow-xl ring-1
              ring-black/5
            "
          >
            <div
              class="
                flex flex-col
                md:flex-row
              "
            >
              <div
                class="
                  w-full
                  md:w-1/3
                "
              >
                <Image
                  src={workingTogetherImg}
                  alt="Working Together"
                  class="
                    h-48 w-full object-cover
                    md:h-full
                  "
                  width={400}
                  height={400}
                />
              </div>
              <div class="flex flex-1 flex-col justify-center p-8">
                <h3
                  class="
                    mb-4 font-heading text-2xl font-bold text-black italic
                  "
                >
                  Working Together
                </h3>
                <p class="font-body text-gray-600">
                  Your donations make it possible for us to continue our work in supporting Buddhist
                  women worldwide.
                </p>
              </div>
            </div>
          </div>

          <div
            class="
              group overflow-hidden rounded-3xl bg-white shadow-xl ring-1
              ring-black/5
            "
          >
            <div
              class="
                flex flex-col
                md:flex-row
              "
            >
              <div
                class="
                  w-full
                  md:w-1/3
                "
              >
                <Image
                  src={amazonSmileImg}
                  alt="Amazon Smile"
                  class="
                    h-48 w-full object-cover
                    md:h-full
                  "
                  width={400}
                  height={400}
                />
              </div>
              <div class="flex flex-1 flex-col justify-center p-8">
                <h3
                  class="
                    mb-4 font-heading text-2xl font-bold text-black italic
                  "
                >
                  Amazon Smile
                </h3>
                <p class="font-body text-gray-600">
                  Support Sakyadhita while you shop at Amazon. A portion of your purchase goes
                  directly to our programs.
                </p>
              </div>
            </div>
          </div>

          {/* Netlify Form Detection Pixel */}
          <form name="_pixel" data-netlify="true" hidden>
            <img alt="" src={PAYPAL_CONFIG.PIXEL_IMG} width="1" height="1" />
          </form>
        </section>
      </div>

      {/* Bottom Section: Join/Involved */}
      <section class="pt-12">
        <div class="mb-12 flex items-center gap-6">
          <h2 class="font-heading text-3xl font-bold tracking-tight text-black">
            More Ways to <span class="text-brand-orange">Connect</span>
          </h2>
          <div class="h-px flex-1 bg-gray-100"></div>
        </div>

        <div
          class="
            grid grid-cols-1 gap-8
            md:grid-cols-2
          "
        >
          <BeInvolved
            title="Join Sakyadhita"
            description="Become a member and join our global network of Buddhist women"
            image_url={JoiningHandsImg}
            openInSameTab="true"
            redirect_link={SITE_PAGES.JOIN_US}
            button_title="Join Us"
          />
          <BeInvolved
            title="Sakyadhita Endowment Fund"
            description="Help secure our future and stay connect by donating in any amount"
            image_url={DonateImg}
            openInSameTab="true"
            redirect_link={SITE_PAGES.DONATE}
            button_title="Donate"
          />
        </div>
      </section>
    </div>
  </div>
</PageLayout>
