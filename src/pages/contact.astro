---
import { getImage } from 'astro:assets'
import { Mail, Phone, House, X } from 'lucide-react'

import HongKongVideo from '../assets/Contact Page/Hong Kong Conference Video.jpeg'
import CustomButton from '../components/CustomButton.astro'
import ResourcesHeader from '../components/ResourcesHeader.astro'
import PageLayout from '../layouts/PageLayout.astro'

const frontmatter = {
  image: HongKongVideo,
  email: [
    {
      address: 'service.sakyadhita@gmail.com',
      description: 'General Enquiries'
    }
  ],
  phone: '+1 858-525-5173 (Hawaiian Standard Time)',
  address: '7331 Princess View Drive, San Diego, CA 92120 USA'
}

const emailInfo = frontmatter.email || []
const phone = frontmatter.phone
const address = frontmatter.address

const optimizedHeader = await getImage({ src: frontmatter.image, format: 'webp', width: 1600 })
const headerImageUrl = optimizedHeader?.src || frontmatter.image.src
---

<PageLayout>
  <div id="contact-page-root" class="
    flex w-full flex-col
    lg:flex-row
  ">
    {/* Responsive Header for Mobile */}
    <div class="
      w-full
      lg:hidden
    ">
      <ResourcesHeader image={headerImageUrl} title="Contact Us" />
    </div>

    {/* The Interactive Form */}
    <div class="flex-1">
      <div class="
        flex h-auto w-full flex-1 flex-col font-body
        lg:flex-row
      ">
        <section
          class="
            prose max-w-none flex-1 p-6 text-left text-black
            md:p-12
            lg:p-24
          "
        >
          <h2
            class="
              mb-5 font-heading text-2xl font-bold tracking-tight text-black
              lowercase
              lg:text-3xl
            "
          >
            Contact Us
          </h2>
          <div class="font-body text-lg/relaxed text-gray-700">
            <p>
              Thank you for your interest in Sakyadhita International and our work to awaken women
              to their tremendous potential for social and spiritual transformation. Please contact
              us for general inquiries and comments, updates on resources and women’s initiatives,
              Dharma offerings, questions about donations or sponsorships, or general
              correspondence.
            </p>

            <p>
              Sakyadhita is volunteer run, so please have patience with us as we answer your email.
              We always strive to answer in a timely manner.
            </p>
          </div>

          <h4
            class="
              mt-10 mb-5 w-fit border-b-2 border-brand-orange font-heading
              text-2xl font-semibold text-black lowercase italic
            "
          >
            Reach us at:
          </h4>

          <div class="space-y-3 font-body">
            {
              emailInfo.map((email: any) => (
                <p class="m-0 flex items-center space-x-2 text-black">
                  <Mail className="size-5 text-brand-orange" />
                  <a
                    href={`mailto:${email.address}`}
                    class="
                      text-black no-underline transition-colors
                      hover:text-brand-orange
                    "
                  >
                    {email.address}
                  </a>
                  ({email.description})
                </p>
              ))
            }
            <p class="m-0 flex items-center space-x-2 text-black">
              <Phone className="size-5 text-brand-orange" />
              <span>{phone}</span>
            </p>
            <div class="flex items-start space-x-2 text-black">
              <House className="mt-1 size-6 shrink-0 text-brand-orange" />
              <span>{address}</span>
            </div>
          </div>

          <h4
            class="
              mt-12 mb-6 font-heading text-2xl font-semibold text-black
              lowercase italic
            "
          >
            Send us a message!
          </h4>

          <form id="contact-form" class="space-y-4" novalidate>
            <div class="flex">
              <input
                name="name"
                type="text"
                placeholder="Full Name"
                class="
                  contact-input m-2 h-12 w-[95%] rounded-3xl border border-black
                  bg-white px-6 font-body
                  focus:ring-1 focus:ring-brand-dark-purple focus:outline-none
                "
                required
              />
              <span class="text-3xl font-bold text-brand-red"> * </span>
            </div>
            <div class="flex">
              <input
                name="email"
                type="email"
                placeholder="Email"
                class="
                  contact-input m-2 h-12 w-[95%] rounded-3xl border border-black
                  bg-white px-6 font-body
                  focus:ring-1 focus:ring-brand-dark-purple focus:outline-none
                "
                required
              />
              <span class="text-3xl font-bold text-brand-red"> * </span>
            </div>
            <div class="flex">
              <input
                name="phone"
                type="tel"
                placeholder="Phone Number"
                class="
                  contact-input m-2 h-12 w-[95%] rounded-3xl border border-black
                  bg-white px-6 font-body
                  focus:ring-1 focus:ring-brand-dark-purple focus:outline-none
                "
              />
              <span class="text-white"> * </span>
            </div>
            <div class="flex">
              <textarea
                name="message"
                placeholder="Write your message here"
                class="
                  contact-input m-2 h-48 w-[95%] resize-none rounded-2xl border
                  border-black bg-white px-6 py-4 font-body
                  focus:ring-1 focus:ring-brand-dark-purple focus:outline-none
                "
                rows="8"
                required></textarea>
              <span class="text-3xl font-bold text-brand-red"> * </span>
            </div>
            <p class="m-0 text-center font-body text-sm text-gray-500">
              <span class="font-bold text-brand-red"> * </span> indicates a required field
            </p>
            <div class="mt-5 flex justify-center py-4">
              <CustomButton text="Submit" id="submit-button" />
            </div>
          </form>

          {/* Simple Snackbar */}
          <div
            id="error-snackbar"
            class="
              fixed bottom-5 left-5 z-50 hidden min-w-80 items-center
              justify-between rounded-lg bg-brand-red px-6 py-3 text-white
              shadow-lg
            "
          >
            <span id="error-message"></span>
            <button id="close-snackbar" class="ml-4 cursor-pointer font-bold">
              <X className="size-4" />
            </button>
          </div>
        </section>
      </div>
    </div>

    {/* The Side Image for Desktop */}
    <div
      class="
        hidden min-h-[500px] flex-1 bg-cover bg-center bg-no-repeat
        lg:block
      "
      style={{ backgroundImage: `url("${headerImageUrl}")` }}
    >
    </div>
  </div>

  {/* Thank You Modal */}
  <div
    id="thank-you-modal"
    class="
      fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4
    "
  >
    <div
      class="
        w-full max-w-md rounded-lg border-2 border-brand-orange bg-white p-8
        shadow-xl
      "
    >
      <p class="px-4 pt-4 text-center font-body text-2xl text-black">
        Thank you for contacting us. We will get in touch with you shortly.
      </p>
      <div class="mt-8 flex justify-center">
        <button
          id="close-modal"
          class="
            h-10 min-w-32 cursor-pointer rounded-full border border-black
            bg-transparent font-body text-lg font-bold text-black
            transition-colors
            hover:bg-gray-100
          "
        >
          Ok
        </button>
      </div>
    </div>
  </div>

  {/* Hidden form for Netlify detection */}
  <form name="contact" data-netlify="true" netlify-honeypot="bot-field" hidden>
    <input type="text" name="name" />
    <input type="email" name="email" />
    <input type="tel" name="phone" />
    <textarea name="message"></textarea>
  </form>
</PageLayout>

<script>
  function initContactForm() {
    const root = document.querySelector('#contact-page-root')
    if (!root) return

    const form = document.querySelector('#contact-form') as HTMLFormElement
    const submitBtn = document.querySelector('#submit-button') as HTMLButtonElement
    const snackbar = document.querySelector('#error-snackbar')
    const errorMessage = document.querySelector('#error-message')
    const closeSnackbar = document.querySelector('#close-snackbar')
    const modal = document.querySelector('#thank-you-modal')
    const closeModal = document.querySelector('#close-modal')

    if (!form || !submitBtn) return

    let isSubmitting = false

    const showSnackbar = (msg: string) => {
      if (errorMessage) errorMessage.textContent = msg
      snackbar?.classList.remove('hidden')
      snackbar?.classList.add('flex')
    }

    const hideSnackbar = () => {
      snackbar?.classList.remove('hidden')
      snackbar?.classList.add('hidden')
    }

    const encode = (data: any) => {
      return Object.keys(data)
        .map((key) => encodeURIComponent(key) + '=' + encodeURIComponent(data[key]))
        .join('&')
    }

    submitBtn.addEventListener('click', async (e) => {
      e.preventDefault()
      if (isSubmitting) return

      hideSnackbar()

      const formData = new FormData(form)
      const data = Object.fromEntries(formData.entries())

      // Validation
      let hasError = false
      const requiredFields = ['name', 'email', 'message']

      form.querySelectorAll('.contact-input').forEach((input) => {
        input.classList.remove('border-brand-red', 'ring-brand-red')
      })

      requiredFields.forEach((field) => {
        const val = data[field] as string
        if (!val || val.trim() === '') {
          hasError = true
          const el = form.querySelector(`[name="${field}"]`)
          el?.classList.add('border-brand-red', 'ring-brand-red')
        }
      })

      if (hasError) {
        showSnackbar('Missing required fields')
        return
      }

      // Submit
      isSubmitting = true
      document.body.style.cursor = 'wait'
      submitBtn.disabled = true

      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: encode({
            'form-name': 'contact',
            ...data
          })
        })

        if (response.ok) {
          modal?.classList.remove('hidden')
          modal?.classList.add('flex')
          form.reset()
        } else {
          throw new Error('Failed to send message')
        }
      } catch (error: any) {
        showSnackbar(error.message || 'An error occurred')
      } finally {
        isSubmitting = false
        document.body.style.cursor = ''
        submitBtn.disabled = false
      }
    })

    closeSnackbar?.addEventListener('click', hideSnackbar)

    closeModal?.addEventListener('click', () => {
      modal?.classList.remove('flex')
      modal?.classList.add('hidden')
    })
  }

  initContactForm()
  document.addEventListener('astro:page-load', initContactForm)
</script>
