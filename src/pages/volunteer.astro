---
import { getCollection } from 'astro:content'

import LotusHeader from '../assets/Lotus_Header.png'
import SectionHeader from '../components/SectionHeader.astro'
import VolunteerComponent from '../components/VolunteerForm.astro'
import PageLayout from '../layouts/PageLayout.astro'

const frontmatter = {
  title: 'Volunteer',
  description: 'Volunteer through Sakyadhita',
  image: LotusHeader
}

const volinterests = await getCollection('volinterest')
const interests = volinterests.map((interest) => ({
  ...interest,
  id: (Number.parseInt(interest.id) - 1).toString()
}))
---

<PageLayout>
  <SectionHeader
    title={frontmatter.title}
    text={frontmatter.description}
    image={frontmatter.image}
  />

  <VolunteerComponent interests={interests}>
    <slot />
  </VolunteerComponent>
</PageLayout>
